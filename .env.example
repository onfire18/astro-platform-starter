# ── Supabase (Login + Profil-Speicherung) ──
# Kopiere diese Datei zu ".env" und trage deine Werte ein.
# Findest du in deinem Supabase-Projekt unter: Settings → API
#
# Ohne diese Werte läuft die App trotzdem – das Profil wird dann
# nur lokal im Browser gespeichert (kein Google-Login).

PUBLIC_SUPABASE_URL=https://deinprojekt.supabase.co
PUBLIC_SUPABASE_ANON_KEY=dein-anon-public-key
