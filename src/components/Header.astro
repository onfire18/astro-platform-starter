---
const navItems = [
    { linkText: 'Funktionen', href: '/#features' },
    { linkText: 'Rechnung', href: '/invoice' },
];

const currentPath = Astro.url.pathname;
---

<nav class="flex flex-wrap items-center justify-between gap-4 py-5 sm:py-7">
    <a href="/" class="no-underline flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-brand-500 to-brand-700 flex items-center justify-center shadow-lg shadow-brand-700/40">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M13 2L3 14H12L11 22L21 10H12L13 2Z" fill="white" stroke-width="0"/>
            </svg>
        </div>
        <span class="text-lg font-bold text-white group-hover:text-brand-300 transition">AutoFlow</span>
    </a>

    <div class="flex items-center gap-1 sm:gap-2">
        {navItems.map((item) => (
            <a
                href={item.href}
                class:list={[
                    'no-underline px-3 py-1.5 rounded-lg text-sm font-medium transition',
                    currentPath === item.href
                        ? 'bg-brand-600/20 text-brand-300'
                        : 'text-neutral-400 hover:text-white hover:bg-white/5',
                ]}
            >
                {item.linkText}
            </a>
        ))}
        <a
            href="/invoice"
            class="no-underline ml-1 px-4 py-1.5 bg-brand-600 hover:bg-brand-500 text-white text-sm font-semibold rounded-lg transition shadow-lg shadow-brand-700/30"
        >
            Starten →
        </a>
    </div>
</nav>
