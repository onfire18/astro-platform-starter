---
import { SITE, whatsappUrl } from '../../config/site';
---

<footer class="md-footer" role="contentinfo">
  <div class="md-container">
    <div class="footer-grid">
      <!-- Brand -->
      <div class="footer-brand">
        <div class="footer-logo">
          <img src="/images/logo.jpeg" alt="MediaDrift Logo" class="footer-logo-img" width="32" height="32" />
          <span class="logo-text">MediaDrift</span>
        </div>
        <p class="footer-tagline">Websites, die nicht nur gut aussehen.<br />Sondern Kunden gewinnen.</p>
        <address class="footer-address not-italic">
          {SITE.contact.company}<br />
          {SITE.contact.name}<br />
          {SITE.contact.street}<br />
          {SITE.contact.city}
        </address>
      </div>

      <!-- Links -->
      <nav aria-label="Footer Navigation">
        <p class="footer-nav-label">Seiten</p>
        <ul role="list">
          <li><a href="/">Startseite</a></li>
          <li><a href="/webdesign">Webdesign</a></li>
          <li><a href="/ueber-uns">Über uns</a></li>
          <li><a href="/vertrieb">Vertriebspartner</a></li>
          <li><a href="/#kontakt">Kontakt</a></li>
        </ul>
      </nav>

      <!-- Legal -->
      <nav aria-label="Rechtliche Hinweise">
        <p class="footer-nav-label">Rechtliches</p>
        <ul role="list">
          <li><a href="/impressum">Impressum</a></li>
          <li><a href="/datenschutz">Datenschutz</a></li>
          <li><a href="/agb">AGB</a></li>
          <li>
            <button
              class="consent-revoke-btn"
              id="footer-consent-btn"
              type="button"
              aria-label="Cookie-Einstellungen ändern"
            >
              Cookie-Einstellungen
            </button>
          </li>
        </ul>
      </nav>

      <!-- Contact -->
      <div>
        <p class="footer-nav-label">Kontakt</p>
        <ul role="list" class="footer-contact">
          <li>
            <a href={`tel:${SITE.contact.phoneClean}`} aria-label={`Anruf: ${SITE.contact.phone}`}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.5a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 2.69h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.09a16 16 0 0 0 6 6l1.46-1.46a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              {SITE.contact.phone}
            </a>
          </li>
          <li>
            <a href={whatsappUrl('customer')} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp schreiben">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12.004 2.003A9.997 9.997 0 0 0 2 12c0 1.763.463 3.448 1.27 4.91L2 22l5.234-1.244A9.97 9.97 0 0 0 12.004 22C17.523 22 22 17.523 22 12S17.523 2.003 12.004 2.003zm0 18.247a8.219 8.219 0 0 1-4.195-1.15l-.3-.178-3.107.737.78-2.997-.197-.307A8.242 8.242 0 0 1 3.752 12c0-4.556 3.706-8.262 8.252-8.262 4.548 0 8.252 3.706 8.252 8.262 0 4.557-3.704 8.25-8.252 8.25z"/></svg>
              WhatsApp schreiben
            </a>
          </li>
          {SITE.contact.email !== '[AKTUELLE E-MAIL EINFÜGEN]' && (
            <li>
              <a href={`mailto:${SITE.contact.email}`}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
                {SITE.contact.email}
              </a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {SITE.contact.company} · {SITE.contact.name} · Alle Rechte vorbehalten</p>
    </div>
  </div>
</footer>

<style>
  .md-footer {
    background: #0A0A0A;
    color: #A1A1AA;
    padding-top: 4rem;
    padding-bottom: 2rem;
    margin-top: 5rem;
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 0.9rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #262626;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
    width: fit-content;
  }
  .footer-logo-img {
    width: 32px;
    height: 32px;
    border-radius: 7px;
    object-fit: cover;
    transition: transform 200ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .footer-logo:hover .footer-logo-img { transform: scale(1.06) rotate(-3deg); }
  }
  .logo-mark {
    width: 32px;
    height: 32px;
    background: var(--md-cta);
    color: #fff;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: 1rem;
  }
  .logo-text {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: 1.05rem;
    color: #FAFAFA;
  }

  .footer-tagline {
    color: #71717A;
    line-height: 1.6;
    margin-bottom: 1.25rem;
    font-size: 0.88rem;
  }

  .footer-address {
    color: #71717A;
    line-height: 1.8;
    font-size: 0.85rem;
  }

  .footer-nav-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #52525B;
    margin-bottom: 1rem;
  }

  nav ul, .footer-contact {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  nav a, .footer-contact a {
    color: #A1A1AA;
    text-decoration: none;
    transition: color 150ms var(--ease-out), transform 200ms var(--ease-out);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  nav a svg, .footer-contact a svg {
    transition: transform 200ms var(--ease-out), color 150ms var(--ease-out);
    flex-shrink: 0;
  }
  @media (hover: hover) and (pointer: fine) {
    nav a:hover, .footer-contact a:hover { color: #FAFAFA; transform: translateX(3px); }
    .footer-contact a:hover svg { color: var(--md-cta-dark, #0284C7); transform: scale(1.1); }
  }

  .consent-revoke-btn {
    background: none;
    border: none;
    color: #A1A1AA;
    cursor: pointer;
    padding: 0;
    font-size: 0.9rem;
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    transition: color 150ms var(--ease-out), transform 200ms var(--ease-out);
    text-align: left;
  }
  @media (hover: hover) and (pointer: fine) {
    .consent-revoke-btn:hover { color: #FAFAFA; transform: translateX(3px); }
  }

  .footer-bottom {
    padding-top: 1.5rem;
    color: #52525B;
    font-size: 0.82rem;
  }

  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
  }

  @media (max-width: 560px) {
    .footer-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  document.getElementById('footer-consent-btn')?.addEventListener('click', () => {
    const banner = document.getElementById('consent-banner');
    if (banner) {
      banner.removeAttribute('hidden');
      banner.setAttribute('aria-hidden', 'false');
    }
  });
</script>
