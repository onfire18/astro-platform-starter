---
import Layout from '../../layouts/Layout.astro';
import InstagramToolkit from '../../components/InstagramToolkit';
---

<Layout title="Instagram-Toolkit" description="Captions, Hashtags und Bio für Instagram generieren – schnell, kostenlos, auf Deutsch.">
    <div class="py-8 sm:py-10 max-w-3xl mx-auto">
        <a href="/" class="inline-flex items-center gap-1.5 text-neutral-500 hover:text-brand-300 text-sm no-underline mb-8 transition">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Zurück zur Startseite
        </a>

        <div class="mb-8">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-pink-600/20 border border-pink-500/30 flex items-center justify-center text-lg">
                    📸
                </div>
                <h1 class="text-2xl sm:text-3xl font-bold text-white" style="font-size: clamp(1.5rem, 4vw, 1.875rem);">Instagram-Toolkit</h1>
            </div>
            <p class="text-neutral-400 text-sm sm:text-base">
                Captions generieren, Hashtags zusammenstellen, Bio optimieren –
                alles in einem Tool.
            </p>
        </div>

        <InstagramToolkit client:load />
    </div>
</Layout>
