  <!-- ═══════════════════════════════════════════
       BEWERBUNGSFORMULAR
  ════════════════════════════════════════════ -->
  <section class="md-section v-form-section" id="bewerbung" aria-labelledby="v-form-h2">
    <div class="md-container v-form-container">
      <div class="v-form-header">
        <span class="md-label">Bewerbung</span>
        <h2 id="v-form-h2" class="v-h2">Jetzt bewerben</h2>
        <p>Kein Lebenslauf, kein Anschreiben. Einfach kurz erzählen, wer du bist — ich meld mich persönlich innerhalb von 24 Stunden.</p>
      </div>

      <form
        name="vertriebspartner"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        id="partner-form"
        class="v-form md-card"
        novalidate
        aria-label="Bewerbungsformular Vertriebspartner"
      >
        <input type="hidden" name="form-name" value="vertriebspartner" />
        <p hidden><label>Nicht ausfüllen: <input name="bot-field" /></label></p>

        <div class="v-form-row">
          <div class="v-form-group">
            <label for="vp-vorname" class="v-label">Vorname <span aria-label="Pflichtfeld" class="v-required">*</span></label>
            <input type="text" id="vp-vorname" name="vorname" required autocomplete="given-name" placeholder="Dein Vorname" class="v-input" aria-required="true" />
          </div>
          <div class="v-form-group">
            <label for="vp-nachname" class="v-label">Nachname <span aria-label="Pflichtfeld" class="v-required">*</span></label>
            <input type="text" id="vp-nachname" name="nachname" required autocomplete="family-name" placeholder="Dein Nachname" class="v-input" aria-required="true" />
          </div>
        </div>

        <div class="v-form-row">
          <div class="v-form-group">
            <label for="vp-email" class="v-label">E-Mail <span aria-label="Pflichtfeld" class="v-required">*</span></label>
            <input type="email" id="vp-email" name="email" required autocomplete="email" placeholder="deine@email.de" class="v-input" aria-required="true" />
          </div>
          <div class="v-form-group">
            <label for="vp-whatsapp" class="v-label">WhatsApp-Nummer <span aria-label="Pflichtfeld" class="v-required">*</span></label>
            <input type="tel" id="vp-whatsapp" name="whatsapp" required autocomplete="tel" placeholder="+49 ..." class="v-input" aria-required="true" />
          </div>
        </div>

        <div class="v-form-group">
          <label for="vp-verfügbarkeit" class="v-label">Wie viel Zeit hast du? <span aria-label="Pflichtfeld" class="v-required">*</span></label>
          <select id="vp-verfügbarkeit" name="verfügbarkeit" required class="v-input" aria-required="true">
            <option value="">Bitte wählen</option>
            <option>Nebenbei (ein paar Stunden pro Woche)</option>
            <option>Regelmäßig (10–20 Std./Woche)</option>
            <option>Vollzeit (das soll mein Hauptjob werden)</option>
          </select>
        </div>

        <div class="v-form-group">
          <label for="vp-erfahrung" class="v-label">Erzähl kurz von dir — woher kommst du, was machst du gerade? <span aria-label="Pflichtfeld" class="v-required">*</span></label>
          <textarea id="vp-erfahrung" name="erfahrung" required rows="3" class="v-input" placeholder="Kein Lebenslauf nötig: z.B. &quot;Ich bin Student und kenne viele Handwerker&quot; oder &quot;Ich war 3 Jahre im Vertrieb.&quot;" aria-required="true"></textarea>
        </div>

        <div class="v-form-group">
          <label for="vp-motivation" class="v-label">Warum meldest du dich? <span aria-label="Pflichtfeld" class="v-required">*</span></label>
          <textarea id="vp-motivation" name="motivation" required rows="3" class="v-input" placeholder="Keine Bewerbungssprache nötig — einfach ehrlich." aria-required="true"></textarea>
        </div>

        <div class="v-form-group v-consent-group">
          <label class="v-consent-label">
            <input type="checkbox" name="datenschutz" required id="vp-datenschutz" aria-required="true" />
            <span>Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Bewerbung zu. <span aria-label="Pflichtfeld" class="v-required">*</span></span>
          </label>
        </div>

        <div class="v-form-actions">
          <button type="submit" class="md-btn md-btn-primary" id="vp-submit">
            Bewerbung absenden
