<script>
  const form = document.getElementById('partner-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('vp-submit') as HTMLButtonElement | null;
  const successMsg = document.getElementById('vp-success') as HTMLElement | null;
  const errorMsg = document.getElementById('vp-error') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!submitBtn || !successMsg || !errorMsg) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Wird gesendet…';
    successMsg.hidden = true;
    errorMsg.hidden = true;

    try {
      const res = await fetch('/', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(new FormData(form) as unknown as Record<string, string>).toString(),
      });
      if (res.ok) {
        form.reset();
        successMsg.hidden = false;
        successMsg.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        errorMsg.hidden = false;
      }
    } catch {
      errorMsg.hidden = false;
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Bewerbung absenden';
    }
  });

  // Clear validity on input
  form?.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.v-input').forEach(field => {
    field.addEventListener('input', () => field.setCustomValidity(''));
  });

  // Journey Roadmap — scroll-triggered animation
  (function () {
    const journey = document.getElementById('v-journey');
    if (!journey) return;

    const io = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          journey.classList.add('is-in');
          io.unobserve(journey);
        }
      },
      { threshold: 0.3 }
    );
    io.observe(journey);
  })();

  // Hero provision count-up (synct mit der Card-Slide-Animation)
  (function () {
    const el = document.querySelector<HTMLElement>('.v-count');
    if (!el) return;
    const target = parseInt(el.dataset.target ?? '10', 10);
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) { el.textContent = String(target); return; }

    el.textContent = '0';
    const duration = 650;
    const startDelay = 480; // startet, wenn die Card hereinkommt
    let startTime: number | null = null;

    function tick(now: number) {
      if (startTime === null) startTime = now;
      const p = Math.min((now - startTime) / duration, 1);
      // ease-out
      const eased = 1 - Math.pow(1 - p, 3);
      el!.textContent = String(Math.round(eased * target));
      if (p < 1) requestAnimationFrame(tick);
      else el!.textContent = String(target);
    }
    window.setTimeout(() => requestAnimationFrame(tick), startDelay);
  })();
</script>

