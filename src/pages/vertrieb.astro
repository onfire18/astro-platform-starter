---
import MDLayout from '../layouts/MDLayout.astro';
import { SITE, whatsappUrl } from '../config/site';
import { faqSales } from '../data/faq';
const waSales = whatsappUrl('sales');
---

<MDLayout
  title="Vertriebspartner werden"
  description="Vermittle Website-Kunden an MediaDrift und erhalte 10 % Provision bei Abschluss. Flexibel, selbstständig, ohne Vorerfahrung im Webdesign."
>

  <!-- ═══════════════════════════════════════════
       HERO
  ════════════════════════════════════════════ -->
  <section class="v-hero" aria-labelledby="v-hero-h1">
    <div class="md-container v-hero-inner">

      <div class="v-hero-content">
        <span class="v-eyebrow v-anim v-anim-eyebrow">Vertriebspartner gesucht</span>
        <h1 id="v-hero-h1" class="v-h1">
          <span class="v-h1-line v-anim v-anim-line1">Öffne Türen.</span><br />
          <span class="v-h1-accent v-h1-line v-anim v-anim-line2">Wir machen den Rest.<span class="v-h1-underline" aria-hidden="true"></span></span>
        </h1>
        <p class="v-subline v-anim v-anim-sub">
          Finde Unternehmen, die eine professionelle Website brauchen – und vermittle
          sie an MediaDrift. Alles danach übernehmen wir. Du erhältst 10 % Provision
          bei erfolgreichem Abschluss.
        </p>

        <div class="v-hero-actions v-anim v-anim-cta">
          <a href="#bewerbung" class="md-btn md-btn-primary v-btn-cta">
            Kennenlerngespräch vereinbaren
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={waSales} class="v-wa-link" target="_blank" rel="noopener noreferrer">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Direkt per WhatsApp
          </a>
        </div>

        <p class="v-legal-note v-anim v-anim-legal" role="note">
          Selbstständige Vertriebspartnerschaft · Erfolgsabhängige Vergütung · Keine Festanstellung
        </p>
      </div>

      <!-- Right: Provision highlight card -->
      <div class="v-hero-card v-anim v-anim-card" aria-hidden="true">
        <div class="v-hero-card-inner">
          <span class="v-hero-card-label">Deine Provision</span>
          <div class="v-hero-card-number"><span class="v-count" data-target="10">10</span><span class="v-percent">%</span></div>
          <span class="v-hero-card-sub">des Netto-Auftragswerts<br />bei jedem Abschluss</span>
          <ul class="v-hero-card-facts">
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              Kein Webdesign-Wissen nötig
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              Flexible Zeiteinteilung
            </li>
            <li>
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              Neben- oder hauptberuflich
            </li>
          </ul>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       WIE ES FUNKTIONIERT (3-Step-Flow)
  ════════════════════════════════════════════ -->
  <section class="md-section v-flow-section" aria-labelledby="v-flow-h2">
    <div class="md-container">
      <span class="md-label">So einfach geht's</span>
      <h2 id="v-flow-h2" class="v-h2">Du bringst den Kontakt — wir schließen ab</h2>

      <div class="v-flow-grid">
        <div class="v-flow-step">
          <div class="v-flow-num">1</div>
          <div class="v-flow-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013 12a19.79 19.79 0 01-3.07-8.67A2 2 0 011.72 1h3.09a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L5.91 8.09a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h3>Du akquirierst</h3>
          <p>Du sprichst Unternehmen an, die eine Website brauchen. Per Telefon, Netzwerk oder persönlich. Deine Aufgabe: Interesse wecken und einen Termin mit MediaDrift vereinbaren.</p>
        </div>

        <div class="v-flow-arrow" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>

        <div class="v-flow-step">
          <div class="v-flow-num">2</div>
          <div class="v-flow-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <h3>Wir übernehmen</h3>
          <p>Sobald Interesse besteht, springt MediaDrift ein: Angebot, Konzept, Verhandlung, Projektabwicklung. Du musst kein Webdesign-Profi sein – das sind wir.</p>
        </div>

        <div class="v-flow-arrow" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </div>

        <div class="v-flow-step">
          <div class="v-flow-num">3</div>
          <div class="v-flow-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
          </div>
          <h3>Provision fließt</h3>
          <p>Nach Vertragsabschluss und Anzahlung erhältst du 10 % des Netto-Auftragswerts. Transparent, nachvollziehbar, direkt mit Paul abgerechnet.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       FÜR WEN
  ════════════════════════════════════════════ -->
  <section class="md-section v-forwhom-section" aria-labelledby="v-forwhom-h2">
    <div class="md-container">
      <span class="md-label">Für wen ist das geeignet?</span>
      <h2 id="v-forwhom-h2" class="v-h2">Passt das zu dir?</h2>

      <div class="v-forwhom-grid">
        <div class="v-forwhom-card v-check">
          <div class="v-forwhom-header">
            <div class="v-forwhom-icon v-icon-green">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            </div>
            <h3>Das bringst du idealerweise mit</h3>
          </div>
          <ul class="v-list v-list-check">
            <li>Erfahrung in Verkauf, Kaltakquise oder Kundenberatung</li>
            <li>Eigeninitiative und Ausdauer beim Erstkontakt</li>
            <li>Kommunikationsstärke und sicheres Auftreten</li>
            <li>Netzwerk in einer oder mehreren Branchen</li>
            <li>Bereitschaft, auf eigene Rechnung tätig zu sein</li>
          </ul>
        </div>

        <div class="v-forwhom-card v-cross">
          <div class="v-forwhom-header">
            <div class="v-forwhom-icon v-icon-red">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
            </div>
            <h3>Weniger geeignet, wenn du</h3>
          </div>
          <ul class="v-list v-list-cross">
            <li>Feste Vergütung unabhängig vom Ergebnis erwartest</li>
            <li>Keine Erfahrung mit Kundenkontakt hast</li>
            <li>Ein Angestelltenverhältnis suchst</li>
            <li>Keine Zeit für aktive Akquise aufbringen kannst</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       ABLAUF – 4 Schritte
  ════════════════════════════════════════════ -->
  <section class="md-section v-steps-section" aria-labelledby="v-steps-h2">
    <div class="md-container">
      <span class="md-label">Ablauf</span>
      <h2 id="v-steps-h2" class="v-h2">Von der Bewerbung zum ersten Abschluss</h2>

      <ol class="v-steps" aria-label="Ablauf der Vertriebspartnerschaft">
        <li class="v-step">
          <div class="v-step-badge">01</div>
          <div class="v-step-line" aria-hidden="true"></div>
          <div class="v-step-body">
            <h3>Kennenlerngespräch</h3>
            <p>Wir besprechen deine Erfahrungen, Ziele und ob die Zusammenarbeit zu beiden Seiten passt. Kein Druck, keine Verpflichtung – ein ehrliches Gespräch.</p>
          </div>
        </li>
        <li class="v-step">
          <div class="v-step-badge">02</div>
          <div class="v-step-line" aria-hidden="true"></div>
          <div class="v-step-body">
            <h3>Einführung & Materialien</h3>
            <p>Du erhältst Gesprächsleitfäden, Zielgruppenprofile und Einwandbehandlungen. Du bist sofort startklar – kein wochenlanges Onboarding.</p>
          </div>
        </li>
        <li class="v-step">
          <div class="v-step-badge">03</div>
          <div class="v-step-line" aria-hidden="true"></div>
          <div class="v-step-body">
            <h3>Akquise & Vermittlung</h3>
            <p>Du nimmst Kontakt auf und vermittelst interessierte Unternehmen an MediaDrift. Ab dem ersten qualifizierten Gespräch übernehmen wir vollständig.</p>
          </div>
        </li>
        <li class="v-step">
          <div class="v-step-badge">04</div>
          <div class="v-step-body">
            <h3>Provision nach Abschluss</h3>
            <p>Nach erfolgreichem Vertragsabschluss und Anzahlung des Kunden werden 10 % des Netto-Auftragswerts als Provision an dich ausbezahlt.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       JOURNEY ROADMAP
  ════════════════════════════════════════════ -->
  <section class="md-section v-journey-section" aria-labelledby="v-journey-h2">
    <div class="md-container">
      <div class="v-journey-header">
        <span class="md-label">Vertriebspartner-Onboarding</span>
        <h2 id="v-journey-h2" class="v-h2">In 5 Schritten zum Partner</h2>
        <p class="md-section-intro" style="margin-bottom:0">Die Roadmap zeichnet sich beim Scrollen Schritt für Schritt ein.</p>
      </div>

      <div class="v-journey" id="v-journey">
        <!-- SVG-Linie (zieht sich von links nach rechts ein) -->
        <svg class="v-journey-svg" aria-hidden="true" preserveAspectRatio="none">
          <line class="v-journey-track" x1="0" y1="50%" x2="100%" y2="50%" />
          <line class="v-journey-progress" x1="0" y1="50%" x2="100%" y2="50%" />
        </svg>

        <ol class="v-journey-steps" role="list">
          {[
            { n: '01', title: 'Kennenlerngespräch', desc: 'Wir klären in 20 Min., ob es passt.' },
            { n: '02', title: 'Onboarding-Kit',     desc: 'Du bekommst alle Unterlagen und Vorlagen.' },
            { n: '03', title: 'Erste Kontakte',     desc: 'Du sprichst Unternehmen in deinem Netzwerk an.' },
            { n: '04', title: 'Projekt übergeben',  desc: 'Wir übernehmen Beratung und Umsetzung.' },
            { n: '05', title: 'Provision kassieren',desc: 'Du erhältst 10 % des Auftragswerts.' },
          ].map(({ n, title, desc }, i) => (
            <li class="v-journey-step" style={`--i:${i}`}>
              <div class="v-journey-badge">{n}</div>
              <h3 class="v-journey-title">{title}</h3>
              <p class="v-journey-desc">{desc}</p>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VERGÜTUNG (Highlight)
  ════════════════════════════════════════════ -->
  <section class="md-section v-provision-section" aria-labelledby="v-provision-h2">
    <div class="md-container">
      <span class="md-label">Vergütung</span>
      <h2 id="v-provision-h2" class="v-h2">Wie die Provision funktioniert</h2>

      <div class="v-provision-card">
        <div class="v-provision-main">
          <div class="v-provision-number">10 <span class="v-provision-pct">%</span></div>
          <div class="v-provision-desc">
            <strong>pro vermitteltem Kunden</strong>
            <span>des Netto-Auftragswerts</span>
          </div>
        </div>
        <div class="v-provision-details">
          <div class="v-provision-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span><strong>Auszahlung</strong> nach Vertragsabschluss und Anzahlung</span>
          </div>
          <div class="v-provision-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span><strong>Vertraglich geregelt</strong> im gemeinsamen Partnervertrag</span>
          </div>
          <div class="v-provision-item">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            <span><strong>Keine Vorabzahlung</strong> – Provision ist rein erfolgsabhängig</span>
          </div>
        </div>
      </div>

      <p class="v-provision-note">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/></svg>
        Die genauen Konditionen werden individuell im Kennenlerngespräch besprochen und schriftlich festgehalten.
        Es handelt sich um eine selbstständige Tätigkeit, keine Festanstellung.
        <span class="v-legal-tag">[RECHTLICH PRÜFEN]</span>
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       UNTERSTÜTZUNG
  ════════════════════════════════════════════ -->
  <section class="md-section v-support-section" aria-labelledby="v-support-h2">
    <div class="md-container">
      <span class="md-label">Was du von uns bekommst</span>
      <h2 id="v-support-h2" class="v-h2">Du startest nicht bei null</h2>

      <div class="v-support-grid">
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div>
            <h3>Zielgruppenprofile</h3>
            <p>Welche Branchen und Unternehmenstypen eignen sich am besten. Mit konkreten Gesprächseinstiegen.</p>
          </div>
        </div>
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
          </div>
          <div>
            <h3>Gesprächsleitfäden</h3>
            <p>Bewährte Skripte für Erstgespräche, typische Einwände und die saubere Übergabe an MediaDrift.</p>
          </div>
        </div>
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          </div>
          <div>
            <h3>Beispiel-Websites</h3>
            <p>Branchenspezifische Musterentwürfe, die du in Gesprächen einsetzen kannst, um das Produkt zu zeigen.</p>
          </div>
        </div>
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <div>
            <h3>Schulungsmaterialien</h3>
            <p>Kurze Videos und Dokumente zu Produkten, Prozessen und häufigen Fragen von Interessenten.</p>
          </div>
        </div>
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
          </div>
          <div>
            <h3>Kontakt-Tracking</h3>
            <p>Einfache Struktur zur Nachverfolgung deiner Kontakte – übersichtlich, ohne komplizierte Systeme.</p>
          </div>
        </div>
        <div class="v-support-item">
          <div class="v-support-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div>
            <h3>Direktes Feedback von Paul</h3>
            <p>Regelmäßiger Austausch, um deinen Ansatz zu verbessern und offene Fragen direkt zu klären.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VORAUSSETZUNGEN
  ════════════════════════════════════════════ -->
  <section class="md-section v-req-section" aria-labelledby="v-req-h2">
    <div class="md-container">
      <span class="md-label">Voraussetzungen</span>
      <h2 id="v-req-h2" class="v-h2">Was du mitbringen solltest</h2>
      <div class="v-req-grid">
        <div class="v-req-item">
          <span class="v-req-num">01</span>
          <h3>Eigenständige Tätigkeit</h3>
