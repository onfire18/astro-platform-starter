    line-height: 1.3;
  }
  .v-step-body p { color: var(--md-muted); font-size: 0.9rem; line-height: 1.65; margin: 0; }

  /* ============================================================
     PROVISION HIGHLIGHT
  ============================================================ */
  .v-provision-section { background: var(--md-bg); }
  .v-provision-card {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 3rem;
    background: var(--md-surface);
    border: 1px solid var(--md-border);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    align-items: center;
    max-width: 820px;
  }
  .v-provision-main {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-shrink: 0;
  }
  .v-provision-number {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: clamp(4rem, 8vw, 6rem);
    color: var(--md-cta);
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .v-provision-pct {
    font-size: 0.55em;
    vertical-align: super;
    color: var(--md-cta-dark);
  }
  .v-provision-desc {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .v-provision-desc strong { font-size: 1.05rem; color: var(--md-primary); display: block; }
  .v-provision-desc span { font-size: 0.9rem; color: var(--md-muted); }
  .v-provision-details {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 1px solid var(--md-border);
    padding-left: 3rem;
  }
  .v-provision-item {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    font-size: 0.9rem;
    color: var(--md-muted);
    line-height: 1.5;
  }
  .v-provision-item svg { flex-shrink: 0; color: var(--md-cta); margin-top: 1px; }
  .v-provision-item strong { color: var(--md-secondary); }
  .v-provision-note {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: var(--md-subtle);
    max-width: 820px;
    line-height: 1.55;
  }
  .v-provision-note svg { flex-shrink: 0; margin-top: 1px; }
  .v-legal-tag {
    background: #FEF9C3;
    color: #78350F;
    padding: 0.05rem 0.35rem;
    border-radius: 3px;
    font-family: monospace;
    font-size: 0.85em;
    white-space: nowrap;
  }
  @media (max-width: 720px) {
    .v-provision-card { grid-template-columns: 1fr; gap: 1.5rem; padding: 2rem 1.75rem; }
    .v-provision-details { border-left: none; padding-left: 0; border-top: 1px solid var(--md-border); padding-top: 1.5rem; }
  }

  /* ============================================================
     SUPPORT
  ============================================================ */
  .v-support-section { background: var(--md-surface); }
  .v-support-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .v-support-item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--md-bg);
    border: 1px solid var(--md-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: box-shadow 250ms var(--ease-out), border-color 250ms var(--ease-out), transform 250ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .v-support-item:hover {
      box-shadow: 0 10px 28px rgba(3,87,133,0.1);
      border-color: rgba(20,85,168,0.25);
      transform: translateY(-2px);
    }
    .v-support-item:hover .v-support-icon { transform: scale(1.07); }
  }
  .v-support-icon {
    width: 40px; height: 40px;
    background: var(--md-accent);
    color: var(--md-cta);
    border-radius: 9px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: transform 250ms var(--ease-out);
  }
  .v-support-item h3 { font-size: 0.95rem; font-weight: 600; color: var(--md-primary); margin-bottom: 0.3rem; }
  .v-support-item p { color: var(--md-muted); font-size: 0.84rem; line-height: 1.6; margin: 0; }
  @media (max-width: 900px) { .v-support-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .v-support-grid { grid-template-columns: 1fr; } }

  /* ============================================================
     REQUIREMENTS
  ============================================================ */
  .v-req-section { background: var(--md-bg); }
  .v-req-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  .v-req-item {
    background: var(--md-surface);
    border: 1px solid var(--md-border);
    border-radius: 12px;
    padding: 1.75rem;
    transition: box-shadow 250ms var(--ease-out), border-color 250ms var(--ease-out), transform 250ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .v-req-item:hover {
      box-shadow: 0 10px 28px rgba(3,87,133,0.1);
      border-color: rgba(20,85,168,0.25);
      transform: translateY(-2px);
    }
    .v-req-item:hover .v-req-num { color: var(--md-cta); }
  }
  .v-req-num {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: 1.75rem;
    color: var(--md-border);
    display: block;
    margin-bottom: 0.5rem;
    line-height: 1;
    transition: color 250ms var(--ease-out);
  }
  .v-req-item h3 { font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif; font-size: 1rem; color: var(--md-primary); margin-bottom: 0.4rem; }
  .v-req-item p { color: var(--md-muted); font-size: 0.88rem; line-height: 1.6; margin: 0; }
  @media (max-width: 700px) { .v-req-grid { grid-template-columns: 1fr; } }

  /* ============================================================
     FAQ
  ============================================================ */
  .v-faq-section { background: var(--md-surface); }
  .v-faq-inner {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 3rem;
    align-items: start;
  }
  .v-faq-header h2 { margin-bottom: 0.5rem; }
  .v-faq-header p { color: var(--md-muted); font-size: 0.9rem; }
  @media (max-width: 700px) { .v-faq-inner { grid-template-columns: 1fr; } }

  /* ============================================================
     FORM
  ============================================================ */
  .v-form-section { background: var(--md-bg); }
  .v-form-container {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: 4rem;
    align-items: start;
  }
  .v-form-header { position: sticky; top: calc(var(--nav-h) + 2rem); }
  .v-form-header h2 { margin-bottom: 0.75rem; }
  .v-form-header p { color: var(--md-muted); font-size: 0.93rem; line-height: 1.65; }
  .v-form { display: flex; flex-direction: column; gap: 0; padding: 2.5rem; }
  .v-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.25rem; margin-bottom: 1.25rem; }
  .v-form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.25rem; }
  .v-form-group:last-child { margin-bottom: 0; }
  .v-label { font-size: 0.875rem; font-weight: 500; color: var(--md-secondary); }
  .v-required { color: var(--md-cta); }
  .v-input {
    border: 1.5px solid var(--md-border);
    border-radius: 7px;
    padding: 0.65rem 0.9rem;
    font-size: 0.95rem;
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    color: var(--md-text);
    background: var(--md-surface);
    resize: vertical;
    width: 100%;
    box-sizing: border-box;
    transition: border-color 160ms var(--ease-out), box-shadow 160ms var(--ease-out);
    min-height: 44px;
  }
  .v-input:focus { outline: none; border-color: var(--md-cta); box-shadow: 0 0 0 3px rgba(20,85,168,0.12); }
  .v-input::placeholder { color: var(--md-subtle); }
  select.v-input { cursor: pointer; }
  .v-consent-group { margin-top: 0.25rem; }
  .v-consent-label { display: flex; align-items: flex-start; gap: 0.6rem; cursor: pointer; font-size: 0.88rem; color: var(--md-muted); line-height: 1.55; }
  .v-consent-label input[type="checkbox"] { margin-top: 0.2rem; flex-shrink: 0; accent-color: var(--md-cta); width: 16px; height: 16px; }
  .v-consent-label a { color: var(--md-cta); text-decoration: underline; }
  .v-form-actions { display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; margin-top: 1.25rem; }
  .v-wa-alt {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--md-muted);
    font-size: 0.88rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 160ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .v-wa-alt:hover { color: var(--md-primary); }
  }
  .v-form-required-note { font-size: 0.8rem; color: var(--md-muted); margin-top: 0.75rem; }
  .v-form-success,
  .v-form-error {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    margin-top: 1.25rem;
  }
  .v-form-success { background: #F0FFF4; border: 1px solid #BBF7D0; }
  .v-form-success strong { color: #15803D; display: block; }
  .v-form-success p { margin: 0.15rem 0 0; color: #16A34A; }
  .v-form-error { background: #FFF5F5; border: 1px solid #FECACA; }
  .v-form-error strong { color: #DC2626; display: block; }
  .v-form-error p { margin: 0.15rem 0 0; color: #EF4444; }
  .v-form-success[hidden], .v-form-error[hidden] { display: none; }
  @media (max-width: 860px) {
    .v-form-container { grid-template-columns: 1fr; gap: 2.5rem; }
    .v-form-header { position: static; }
    .v-form-row { grid-template-columns: 1fr; }
    .v-form { padding: 1.75rem; }
  }

  /* ============================================================
     CLOSING CTA
  ============================================================ */
  .v-closing-section {
    background: #080C14;
    padding-block: clamp(4rem, 7vw, 6rem);
  }
  .v-closing-inner { max-width: 680px; margin-inline: auto; text-align: center; }
  .v-closing-h2 {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    color: #F1F5F9;
    font-weight: 700;
    margin-bottom: 0.75rem;
    text-wrap: balance;
  }
  .v-closing-sub { color: #64748B; margin-bottom: 2.5rem; font-size: 1rem; }
  .v-closing-actions { display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center; }
  .v-closing-btn {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 1.1rem 1.75rem;
    text-decoration: none;
    color: #F1F5F9;
    min-width: 220px;
    flex: 1;
    max-width: 280px;
    transition: background 200ms var(--ease-out), border-color 200ms var(--ease-out), transform 200ms var(--ease-out), box-shadow 200ms var(--ease-out);
  }
  .v-closing-btn:active { transform: scale(0.98); transition-duration: 80ms; }
  .v-closing-btn strong { display: block; font-weight: 600; font-size: 0.95rem; margin-bottom: 0.1rem; }
  .v-closing-btn span { font-size: 0.8rem; color: #64748B; }
  .v-wa-closing svg { color: #25D366; flex-shrink: 0; }
  .v-closing-btn:not(.v-wa-closing) svg { color: #60A5FA; flex-shrink: 0; }
  @media (hover: hover) and (pointer: fine) {
    .v-closing-btn:hover {
      background: rgba(255,255,255,0.09);
      border-color: rgba(255,255,255,0.2);
      transform: translateY(-2px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.3);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .v-closing-btn { transition-property: background, border-color; }
    .v-closing-btn:hover { transform: none; }
    .v-closing-btn:active { transform: none; }
  }
  @media (max-width: 560px) { .v-closing-actions { flex-direction: column; align-items: center; } }

  /* ---- Journey Roadmap ---- */
  .v-journey-section { background: var(--md-surface); }
  .v-journey-header { text-align: center; margin-bottom: 3.5rem; }

  .v-journey {
    position: relative;
    padding-bottom: 0.5rem;
  }

  /* SVG connecting line */
  .v-journey-svg {
    position: absolute;
    top: 27px; /* center of badge */
    left: calc(10% + 27px); /* start from center of first badge */
    width: calc(80% - 54px);
    height: 4px;
    overflow: visible;
    pointer-events: none;
  }
  .v-journey-track {
    stroke: #CBD5E1;
    stroke-width: 2;
    stroke-dasharray: 6 5;
  }
  .v-journey-progress {
    stroke: var(--md-cta);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-dasharray: 1000;
    stroke-dashoffset: 1000;
    transition: stroke-dashoffset 900ms cubic-bezier(0.23, 1, 0.32, 1);
  }
  .v-journey.is-in .v-journey-progress {
    stroke-dashoffset: 0;
  }

  /* Steps list */
  .v-journey-steps {
    position: relative;
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0;
  }
  .v-journey-step {
    flex: 1;
    text-align: center;
    padding: 0 10px;
    opacity: 0;
    transform: scale(0.75);
    transition:
      opacity 350ms cubic-bezier(0.23, 1, 0.32, 1),
      transform 350ms cubic-bezier(0.23, 1, 0.32, 1);
    transition-delay: calc(200ms + var(--i) * 120ms);
  }
  .v-journey.is-in .v-journey-step {
    opacity: 1;
    transform: scale(1);
  }

  .v-journey-badge {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    background: #F1F5F9;
    border: 2px solid #CBD5E1;
    color: #94A3B8;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0 auto;
    transition:
      background 400ms cubic-bezier(0.23, 1, 0.32, 1),
      border-color 400ms cubic-bezier(0.23, 1, 0.32, 1),
      color 400ms cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 400ms cubic-bezier(0.23, 1, 0.32, 1);
    transition-delay: calc(200ms + var(--i) * 120ms);
  }
  .v-journey.is-in .v-journey-badge {
    background: var(--md-cta);
    border-color: var(--md-cta);
    color: #fff;
    box-shadow: 0 6px 16px rgba(20, 85, 168, 0.3);
  }

  .v-journey-title {
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--md-primary);
    margin: 1.1rem 0 0.4rem;
  }
  .v-journey-desc {
    font-family: 'Plus Jakarta Sans Variable', 'Plus Jakarta Sans', system-ui, sans-serif;
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--md-muted);
    text-wrap: pretty;
  }

  /* Mobile: vertikal stapeln */
  @media (max-width: 700px) {
    .v-journey-svg { display: none; }
    .v-journey-steps { flex-direction: column; gap: 1.5rem; align-items: flex-start; }
    .v-journey-step { flex: none; width: 100%; text-align: left; padding: 0; display: flex; align-items: flex-start; gap: 1rem; }
    .v-journey-badge { flex-shrink: 0; }
    .v-journey-title { margin-top: 0.25rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .v-journey-step,
    .v-journey-badge,
    .v-journey-progress { transition: none !important; }
    .v-journey-step { opacity: 1; transform: none; }
    .v-journey-badge { background: var(--md-cta); border-color: var(--md-cta); color: #fff; box-shadow: 0 6px 16px rgba(20,85,168,0.3); }
    .v-journey-progress { stroke-dashoffset: 0; }
  }

  /* ============================================================
     PAUL STELLT SICH VOR
  ============================================================ */
  .v-paul-section {
    background: var(--md-surface);
    border-top: 1px solid var(--md-border);
    border-bottom: 1px solid var(--md-border);
    padding-block: clamp(3rem, 8vw, 6rem);
  }
  .v-paul-inner {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 4rem;
    align-items: center;
  }
  @media (max-width: 820px) {
    .v-paul-inner { grid-template-columns: 1fr; gap: 2rem; }
  }
  .v-paul-img-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .v-paul-img {
    width: 100%;
    max-width: 320px;
    height: 360px;
    object-fit: cover;
    border-radius: 18px;
    display: block;
    box-shadow: 0 12px 48px rgba(20,85,168,0.12);
  }
  .v-paul-placeholder {
    width: 100%;
    max-width: 320px;
    height: 360px;
    border-radius: 18px;
    background: var(--md-accent);
    color: var(--md-subtle);
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    border: 2px dashed var(--md-border);
  }
  .v-paul-badge {
    position: absolute;
    bottom: -14px;
    right: -14px;
    background: var(--md-surface);
    border: 1px solid var(--md-border);
    border-radius: 99px;
    padding: 0.45rem 0.9rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--md-primary);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    box-shadow: 0 4px 16px rgba(20,85,168,0.1);
    white-space: nowrap;
  }
  .v-paul-badge svg { color: var(--md-cta); flex-shrink: 0; }
  .v-paul-text { max-width: 56ch; }
  .v-paul-p {
    color: var(--md-muted);
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .v-paul-p:last-of-type { margin-bottom: 1.5rem; }
  .v-paul-p strong { color: var(--md-primary); }
  .v-paul-sign {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    margin: 0.25rem 0 1.5rem;
  }
  .v-paul-sign-name {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-style: italic;
    font-weight: 600;
    font-size: 1.6rem;
    color: var(--md-cta);
    transform: rotate(-3deg);
    transform-origin: left center;
    width: max-content;
  }
  .v-paul-sign-role {
    font-size: 0.8rem;
    color: var(--md-subtle);
    margin-top: 0.35rem;
  }
  .v-paul-actions {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  /* ============================================================
     EARNINGS CALCULATOR
  ============================================================ */
  .v-calc {
    margin-top: 2rem;
    background: linear-gradient(135deg, #EFF6FF 0%, #EFF2F7 100%);
    border: 1px solid var(--md-border);
    border-radius: 14px;
    padding: 1.5rem 2rem;
    max-width: 820px;
  }
  .v-calc-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--md-subtle);
    margin-bottom: 1rem;
  }
  .v-calc-rows { display: flex; flex-direction: column; gap: 0.6rem; }
  .v-calc-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.65rem 1rem;
    background: var(--md-surface);
    border: 1px solid var(--md-border);
    border-radius: 10px;
    font-size: 0.92rem;
  }
  .v-calc-row--mid { border-color: rgba(20,85,168,0.25); }
  .v-calc-row--top {
    background: var(--md-accent);
    border-color: rgba(20,85,168,0.3);
  }
  .v-calc-auftrag { color: var(--md-muted); min-width: 120px; }
  .v-calc-arrow { color: var(--md-subtle); flex-shrink: 0; }
  .v-calc-result { color: var(--md-primary); }
  .v-calc-result strong { color: var(--md-cta); font-size: 1rem; }
  .v-calc-hint { margin-top: 0.85rem; font-size: 0.8rem; color: var(--md-subtle); }
  @media (max-width: 480px) {
    .v-calc { padding: 1.25rem; }
    .v-calc-auftrag { min-width: auto; }
  }

  /* ============================================================
     TESTIMONIALS
  ============================================================ */
  .v-testimonial-section { background: var(--md-bg); }
  .v-testimonial-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    max-width: 860px;
  }
  @media (max-width: 680px) { .v-testimonial-grid { grid-template-columns: 1fr; } }
  .v-testimonial-card {
    background: var(--md-surface);
    border: 1px solid var(--md-border);
    border-radius: 16px;
    padding: 1.75rem;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-shadow: 0 4px 20px rgba(20,85,168,0.05);
    transition: box-shadow 250ms var(--ease-out), transform 250ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .v-testimonial-card:hover { box-shadow: 0 8px 32px rgba(20,85,168,0.1); transform: translateY(-2px); }
  }
