<style>
  /* ---- Animations ---- */
  @keyframes fadeinup {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes floatbob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes floatcard {
    0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-6px) rotate(var(--rot, 0deg)); }
  }
  .animate-fadeinup {
    opacity: 0;
    animation: fadeinup 0.7s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .animate-delay-1 { animation-delay: 0.15s; }
  .animate-delay-2 { animation-delay: 0.3s; }
  .animate-floatup {
    opacity: 0;
    animation: fadeinup 0.6s cubic-bezier(0.22,1,0.36,1) forwards, floatcard 4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fadeinup, .animate-floatup { animation: none; opacity: 1; }
  }

  /* ---- Hero ---- */
  .hero {
    background: linear-gradient(160deg, #F8FAFC 60%, #EFF6FF 100%);
    padding-top: calc(var(--nav-h) + 3rem);
    padding-bottom: 4rem;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-label {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--md-cta);
    background: var(--md-accent);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
  }
  .hero-h1 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.12;
    color: var(--md-primary);
    margin-bottom: 1.5rem;
  }
  .hero-highlight { color: var(--md-cta); }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--md-secondary);
    line-height: 1.7;
    max-width: 42ch;
    margin-bottom: 2.25rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .hero-btn-primary { display: flex; align-items: center; gap: 0.5rem; }
  .hero-sales-hint { font-size: 0.88rem; color: var(--md-muted); }
  .hero-sales-hint a { color: var(--md-cta); text-decoration: underline; font-weight: 500; }

  /* ---- Mockup slider ---- */
  .hero-visual { position: relative; }

  .mockup-slider-wrap { position: relative; }

  .mock-browser {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 24px 80px rgba(15,23,42,0.14), 0 4px 16px rgba(15,23,42,0.07);
    overflow: hidden;
    border: 1px solid #E2E8F0;
  }
  .mock-chrome {
    background: #F1F5F9;
    border-bottom: 1px solid #E2E8F0;
    padding: 0.55rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }
  .mock-dots { display: flex; gap: 5px; flex-shrink: 0; }
  .dot { width: 9px; height: 9px; border-radius: 50%; }
  .dot-r { background: #EF4444; }
  .dot-y { background: #F59E0B; }
  .dot-g { background: #22C55E; }
  .mock-url {
    flex: 1;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 5px;
    padding: 0.22rem 0.55rem;
    font-size: 0.7rem;
    color: #64748B;
    display: flex;
    align-items: center;
    gap: 0.3rem;
    transition: color 0.4s ease;
  }

  /* Slides */
  .mock-slides {
    position: relative;
    height: 248px;
    overflow: hidden;
  }
  .mock-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.55s ease;
    display: flex;
    flex-direction: column;
  }
  .mock-slide.active { opacity: 1; }
  .mock-slide.slide-out {
    opacity: 0;
    pointer-events: none;
  }

  /* Inner nav */
  .ms-nav {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.5rem 0.9rem;
  }
  .ms-logo { display: flex; align-items: center; gap: 0.35rem; }
  .ms-links { display: flex; gap: 0.7rem; flex: 1; }
  .ms-links span { font-size: 0.58rem; }
  .ms-cta {
    font-size: 0.56rem;
    padding: 0.26rem 0.58rem;
    border-radius: 4px;
    color: #fff;
    white-space: nowrap;
  }

  /* Body */
  .ms-body {
    display: grid;
    grid-template-columns: 1fr 0.75fr;
    gap: 0.85rem;
    padding: 1rem 0.9rem 0.85rem;
    flex: 1;
    align-items: center;
  }
  .ms-left {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .ms-eyebrow {
    font-size: 0.56rem;
    font-weight: 600;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }
  .ms-title-group { display: flex; flex-direction: column; gap: 5px; }
  .ms-title-bar { height: 8px; border-radius: 2px; }
  .ms-sub-group { display: flex; flex-direction: column; gap: 4px; margin-top: 0.15rem; }
  .ms-sub-bar { height: 5px; background: #CBD5E1; border-radius: 2px; }
  .ms-btn {
    display: inline-block;
    font-size: 0.58rem;
    padding: 0.32rem 0.7rem;
    border-radius: 4px;
    color: #fff;
    margin-top: 0.3rem;
    align-self: flex-start;
    white-space: nowrap;
  }
  .ms-right {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ms-card {
    padding: 0.65rem;
    border-radius: 8px;
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .ms-avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    margin-bottom: 0.2rem;
  }
  .ms-stars { font-size: 0.52rem; margin-top: 0.1rem; }
  .ms-service-chip {
    padding: 0.3rem 0.55rem;
    border-radius: 5px;
    font-size: 0.58rem;
    font-weight: 500;
  }

  /* Slider dots */
  .slider-dots-row {
    display: flex;
    justify-content: center;
    gap: 0.45rem;
    margin-top: 0.85rem;
  }
  .sdot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    background: #CBD5E1;
    cursor: pointer;
    padding: 0;
    transition: background 220ms, width 220ms, border-radius 220ms;
  }
  .sdot.active {
    background: var(--md-cta);
    width: 22px;
    border-radius: 4px;
  }

  /* Floating stat cards */
  .float-card {
    position: absolute;
    background: #fff;
    border-radius: 12px;
    padding: 0.65rem 0.9rem;
    box-shadow: 0 8px 32px rgba(15,23,42,0.12), 0 2px 8px rgba(15,23,42,0.06);
    border: 1px solid #F1F5F9;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    min-width: 130px;
    z-index: 10;
    animation-delay: 0.5s !important;
  }
  .float-card-1 { top: -0.75rem; left: -2rem; --rot: -2deg; }
  .float-card-2 { bottom: 2.5rem; left: -2rem; --rot: 1deg; animation-delay: 0.7s !important; }

  .float-card-icon {
    width: 26px; height: 26px;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }
  .fc-green { background: #DCFCE7; color: #16A34A; }
  .float-card-label { display: block; font-size: 0.64rem; color: #94A3B8; margin-bottom: 1px; }
  .float-card-value { display: block; font-size: 1.15rem; font-weight: 700; color: var(--md-primary); line-height: 1.1; }
  .fc-value-green { color: #16A34A; }
  .float-card-badge {
    display: inline-block;
    font-size: 0.63rem;
    background: #DCFCE7;
    color: #16A34A;
    padding: 0.12rem 0.42rem;
    border-radius: 4px;
    margin-top: 2px;
    font-weight: 600;
  }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; gap: 3rem; }
    .hero-visual { display: none; }
  }

  /* ---- Trust ---- */
  .trust-section {
    background: var(--md-bg);
    padding-block: 3rem;
    border-bottom: 1px solid var(--md-border);
  }
  .trust-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .trust-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .trust-card h3 { font-size: 1.05rem; margin: 0; }
  .trust-card p { margin: 0; color: var(--md-muted); font-size: 0.93rem; }
  @media (max-width: 700px) { .trust-grid { grid-template-columns: 1fr; } }

  /* ---- Compare ---- */
  .compare-section { background: var(--md-surface); }
  .compare-section h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-block: 0.5rem 2.5rem; }
  .compare-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .compare-card {
    background: var(--md-surface);
    border: 1.5px solid var(--md-border);
    border-radius: 10px;
    padding: 1.75rem;
  }
  .compare-bad { border-color: #FECACA; background: #FFF5F5; }
  .compare-good { border-color: #BBF7D0; background: #F0FFF4; }
  .compare-card h3 {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.05rem;
    margin-block: 0 1rem;
  }
  .compare-icon { display: flex; align-items: center; }
  .compare-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.6rem; }
  .compare-bad .compare-list li::before { content: '—'; color: #EF4444; margin-right: 0.5rem; font-weight: 700; }
  .compare-good .compare-list li::before { content: '✓'; color: #22C55E; margin-right: 0.5rem; font-weight: 700; }
  .compare-list li { font-size: 0.93rem; color: var(--md-secondary); padding-left: 1.5rem; text-indent: -1.5rem; }
  @media (max-width: 640px) { .compare-grid { grid-template-columns: 1fr; } }

  /* ---- Services ---- */
  .services-section { background: var(--md-bg); }
  .services-section h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-block: 0.5rem 2.5rem; }
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .service-card { display: flex; flex-direction: column; gap: 0.75rem; }
  .service-card h3 { font-size: 1.02rem; margin: 0; }
  .service-card p { margin: 0; color: var(--md-muted); font-size: 0.93rem; line-height: 1.6; }
  .service-icon { flex-shrink: 0; }
  @media (max-width: 900px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .services-grid { grid-template-columns: 1fr; } }

  /* ---- Process ---- */
  .process-section {
    background: var(--md-primary);
    color: var(--md-bg);
  }
  .process-section h2 { color: #F8FAFC; font-size: clamp(1.6rem, 3vw, 2.25rem); margin-block: 0.5rem 2.5rem; }

  .process-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3.5rem;
    align-items: start;
  }
  .process-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .process-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding-block: 1.4rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    opacity: 0.4;
    transition: opacity 0.45s ease, transform 0.45s ease;
  }
  .process-step:last-child { border-bottom: none; }
  .process-step.is-active { opacity: 1; }
  .process-step.is-done { opacity: 0.85; }

  .step-number {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: 2.5rem;
    color: var(--md-cta);
    line-height: 1;
    min-width: 3rem;
    flex-shrink: 0;
    opacity: 0.5;
    position: relative;
    transition: color 0.45s ease, opacity 0.45s ease;
  }
  .process-step.is-active .step-number { color: #60A5FA; opacity: 1; }
  .process-step.is-done .step-number { color: #22C55E; opacity: 1; }
  .process-step h3 { color: #F8FAFC; font-size: 1.05rem; margin: 0 0 0.35rem; }
  .process-step p { color: #94A3B8; margin: 0; font-size: 0.93rem; line-height: 1.65; }

  /* Process visual (building website) */
  .process-visual {
    position: sticky;
    top: calc(var(--nav-h) + 2rem);
  }
  .pv-browser {
    position: relative;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 24px 80px rgba(0,0,0,0.4);
    border: 1px solid #334155;
  }
  .pv-chrome {
    background: #F1F5F9;
    padding: 0.6rem 0.9rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid #E2E8F0;
  }
  .pv-dot { width: 9px; height: 9px; border-radius: 50%; background: #CBD5E1; flex-shrink: 0; }
  .pv-url {
    flex: 1;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 5px;
    padding: 0.2rem 0.55rem;
    font-size: 0.68rem;
    color: #94A3B8;
    margin-left: 0.4rem;
  }
  .pv-screen {
    position: relative;
    height: 300px;
    padding: 1rem;
    background: linear-gradient(135deg, #F8FAFC 0%, #EFF6FF 100%);
    overflow: hidden;
  }

  /* analysis placeholder */
  .pv-analysis {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    color: #64748B;
    font-size: 0.85rem;
    transition: opacity 0.4s ease;
  }
  .pv-analysis svg { animation: pvpulse 1.6s ease-in-out infinite; }
  @keyframes pvpulse { 0%,100% { opacity: 0.4; transform: scale(0.95);} 50% { opacity: 1; transform: scale(1.05);} }
  .pv-browser[data-phase="0"] .pv-analysis { opacity: 1; }
  .pv-browser:not([data-phase="0"]) .pv-analysis { opacity: 0; pointer-events: none; }

  /* wireframe blocks */
  .pv-wire {
    position: absolute;
    border-radius: 4px;
    background: #CBD5E1;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.45s ease, transform 0.45s ease, background 0.45s ease;
  }
  .pv-wire-nav { top: 16px; left: 16px; right: 16px; height: 22px; }
  .pv-wire-h1  { top: 58px; left: 16px; width: 55%; height: 16px; }
  .pv-wire-h2  { top: 82px; left: 16px; width: 40%; height: 10px; }
  .pv-wire-btn { top: 104px; left: 16px; width: 80px; height: 22px; }
  .pv-wire-img { top: 58px; right: 16px; width: 38%; height: 68px; }
  .pv-wire-c1  { bottom: 16px; left: 16px; width: calc(33% - 16px); height: 70px; }
  .pv-wire-c2  { bottom: 16px; left: calc(33% + 4px); width: calc(33% - 16px); height: 70px; }
  .pv-wire-c3  { bottom: 16px; right: 16px; width: calc(33% - 16px); height: 70px; }

  /* phase 1: wireframe visible (grey) */
  .pv-browser[data-phase="1"] .pv-wire,
  .pv-browser[data-phase="2"] .pv-wire,
  .pv-browser[data-phase="3"] .pv-wire,
  .pv-browser[data-phase="4"] .pv-wire,
  .pv-browser[data-phase="5"] .pv-wire {
    opacity: 1;
    transform: translateY(0);
  }
  /* phase 2+: design colors in */
  .pv-browser[data-phase="2"] .pv-wire-nav,
  .pv-browser[data-phase="3"] .pv-wire-nav,
  .pv-browser[data-phase="4"] .pv-wire-nav,
  .pv-browser[data-phase="5"] .pv-wire-nav { background: #0F172A; }
  .pv-browser[data-phase="2"] .pv-wire-h1,
  .pv-browser[data-phase="3"] .pv-wire-h1,
  .pv-browser[data-phase="4"] .pv-wire-h1,
  .pv-browser[data-phase="5"] .pv-wire-h1 { background: #1E293B; }
  .pv-browser[data-phase="2"] .pv-wire-btn,
  .pv-browser[data-phase="3"] .pv-wire-btn,
  .pv-browser[data-phase="4"] .pv-wire-btn,
  .pv-browser[data-phase="5"] .pv-wire-btn { background: #0369A1; }
  .pv-browser[data-phase="2"] .pv-wire-img,
  .pv-browser[data-phase="3"] .pv-wire-img,
  .pv-browser[data-phase="4"] .pv-wire-img,
  .pv-browser[data-phase="5"] .pv-wire-img { background: linear-gradient(135deg,#3B82F6,#0369A1); }
  .pv-browser[data-phase="2"] .pv-wire-c1, .pv-browser[data-phase="3"] .pv-wire-c1, .pv-browser[data-phase="4"] .pv-wire-c1, .pv-browser[data-phase="5"] .pv-wire-c1,
  .pv-browser[data-phase="2"] .pv-wire-c2, .pv-browser[data-phase="3"] .pv-wire-c2, .pv-browser[data-phase="4"] .pv-wire-c2, .pv-browser[data-phase="5"] .pv-wire-c2,
  .pv-browser[data-phase="2"] .pv-wire-c3, .pv-browser[data-phase="3"] .pv-wire-c3, .pv-browser[data-phase="4"] .pv-wire-c3, .pv-browser[data-phase="5"] .pv-wire-c3 {
    background: #fff; box-shadow: 0 2px 8px rgba(15,23,42,0.08); border: 1px solid #E2E8F0;
  }

  /* LIVE badge appears at phase 4 */
  .pv-live-badge {
    position: absolute;
    top: 10px; right: 10px;
    background: #22C55E;
    color: #fff;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    opacity: 0;
    transform: scale(0.6);
    transition: opacity 0.4s ease, transform 0.4s ease;
    z-index: 4;
  }
  .pv-browser[data-phase="4"] .pv-live-badge,
  .pv-browser[data-phase="5"] .pv-live-badge { opacity: 1; transform: scale(1); }

  /* DONE pop overlay at phase 5 */
  .pv-done {
    position: absolute;
    inset: 0;
    background: rgba(15,23,42,0.92);
    backdrop-filter: blur(2px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.3rem;
    color: #fff;
    text-align: center;
    opacity: 0;
    transform: scale(1.08);
    pointer-events: none;
    transition: opacity 0.45s ease, transform 0.45s ease;
    z-index: 5;
  }
  .pv-done strong { font-family: 'DM Serif Display', Georgia, serif; font-size: 1.25rem; font-weight: 400; }
  .pv-done span { color: #94A3B8; font-size: 0.9rem; }
  .pv-done-check {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: #22C55E;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 0.6rem;
    transform: scale(0);
  }
  .pv-browser[data-phase="5"] .pv-done {
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
    animation: pvpop 0.5s cubic-bezier(0.34,1.56,0.64,1);
  }
  .pv-browser[data-phase="5"] .pv-done-check {
    animation: pvcheckpop 0.5s 0.15s cubic-bezier(0.34,1.56,0.64,1) forwards;
  }
  @keyframes pvpop { 0% { transform: scale(1.12); } 60% { transform: scale(0.97);} 100% { transform: scale(1);} }
  @keyframes pvcheckpop { 0% { transform: scale(0) rotate(-20deg);} 100% { transform: scale(1) rotate(0);} }

  .pv-caption {
    text-align: center;
    margin-top: 1rem;
    color: #93C5FD;
    font-size: 0.9rem;
    font-weight: 500;
    min-height: 1.4em;
    transition: color 0.3s ease;
  }

  .process-cta {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .process-cta p { color: #CBD5E1; margin: 0; font-size: 1.05rem; }

  @media (prefers-reduced-motion: reduce) {
    .process-step { opacity: 1; }
    .process-step .step-number { opacity: 1; }
    .pv-wire { opacity: 1; transform: none; }
    .pv-analysis { display: none; }
  }
  @media (max-width: 860px) {
    .process-layout { grid-template-columns: 1fr; gap: 2.5rem; }
    .process-visual { position: static; max-width: 460px; margin-inline: auto; width: 100%; }
  }

  /* ---- Industries ---- */
  .industries-section { background: var(--md-surface); }
  .industries-section h2 { font-size: clamp(1.6rem, 3vw, 2.25rem); margin-block: 0.5rem 0.75rem; }
  .industries-intro { color: var(--md-muted); margin-bottom: 2rem; max-width: 60ch; }
  .industry-tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  .industry-tab {
    padding: 0.5rem 1.1rem;
    border-radius: 6px;
    border: 1.5px solid var(--md-border);
    background: transparent;
    color: var(--md-secondary);
    font-family: 'Jost', system-ui, sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: border-color 150ms, color 150ms, background 150ms;
    min-height: 40px;
  }
  .industry-tab:hover { border-color: var(--md-cta); color: var(--md-cta); }
  .industry-tab.active { background: var(--md-cta); color: #fff; border-color: var(--md-cta); }
  .industry-panel { display: none; }
  .industry-panel.active { display: block; }
  .panel-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    align-items: center;
    background: var(--md-bg);
    border: 1px solid var(--md-border);
    border-radius: 12px;
    padding: 2.5rem;
  }
  .panel-text h3 { font-size: 1.4rem; margin-block: 0 0.75rem; }
  .panel-text p { color: var(--md-muted); margin-bottom: 1.25rem; }
  .panel-pages .md-label { margin-bottom: 0.5rem; }
  .page-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; list-style: none; padding: 0; margin: 0; }
  .page-chip {
    padding: 0.25rem 0.65rem;
    background: var(--md-accent);
    color: var(--md-cta);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
  }
