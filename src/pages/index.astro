    align-items: flex-start;
    padding-block: 1.4rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    opacity: 0.4;
    transition: opacity 0.45s var(--ease-out), transform 0.45s var(--ease-out);
  }
  .process-step:last-child { border-bottom: none; }
  .process-step.is-active { opacity: 1; }
  .process-step.is-done { opacity: 0.85; }

  .step-number {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: 2.5rem;
    color: var(--md-cta);
    line-height: 1;
    min-width: 3rem;
    flex-shrink: 0;
    opacity: 0.5;
    position: relative;
    transition: color 0.45s var(--ease-out), opacity 0.45s var(--ease-out);
  }
  .process-step.is-active .step-number { color: #60A5FA; opacity: 1; }
  .process-step.is-done .step-number { color: #22C55E; opacity: 1; }
  .process-step h3 { color: #F8FAFC; font-size: 1.05rem; margin: 0 0 0.35rem; }
  .process-step p { color: #94A3B8; margin: 0; font-size: 0.93rem; line-height: 1.65; }

  /* =====================================================================
     Prozess-Browser-Animation — CSS-only
     Steuerung ausschließlich über  .pv-browser[data-phase="0..5"]
     Farben:  BG #1E293B · Blau #0369A1 · Grün #22C55E
     ===================================================================== */

  .pv-browser{
    --pv-bg:#1E293B;
    --pv-blue:#0369A1;
    --pv-green:#22C55E;
    --pv-wire:#475569;     /* gestrichelte Wireframe-Linie */
    --pv-skel:#334155;     /* gefüllter Skeleton-Block       */
    --pv-ink:#e2e8f0;

    container-type:inline-size;
    position:relative;
    width:100%;
    aspect-ratio:16 / 10;
    background:var(--pv-bg);
    border-radius:14px;
    overflow:hidden;
    box-shadow:0 28px 70px -24px rgba(2,6,23,.7), 0 0 0 1px rgba(255,255,255,.04);
    font-family:'Inter',system-ui,-apple-system,sans-serif;
  }

  /* ---------- Browser-Chrome ---------- */
  .pv-chrome{
    position:relative; z-index:6;
    display:flex; align-items:center; gap:8px;
    height:38px; padding:0 14px;
    background:#0f172a;
    border-bottom:1px solid rgba(255,255,255,.06);
  }
  .pv-dot{ width:11px; height:11px; border-radius:50%; flex:none; background:#475569; }
  .pv-dot:nth-child(1){ background:#ef4444; }
  .pv-dot:nth-child(2){ background:#f59e0b; }
  .pv-dot:nth-child(3){ background:#22c55e; }
  .pv-url{
    flex:1; margin-left:8px; height:22px; border-radius:6px;
    background:rgba(255,255,255,.06);
    display:flex; align-items:center; padding:0 10px;
  }
  .pv-url-text{ font:600 11px/1 ui-monospace,'SF Mono',monospace; color:#94a3b8; letter-spacing:.2px; }

  /* ---------- Bildschirm ---------- */
  .pv-screen{ position:absolute; inset:38px 0 0 0; overflow:hidden; }

  /* ====================================================================
     PHASE 0 — leeres Fenster, blinkender Cursor, drehendes Analyse-Icon
     ==================================================================== */
  .pv-analysis{
    position:absolute; inset:0; z-index:4;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:20px; font-size:0;                 /* versteckt evtl. Roh-Text "..."  */
    opacity:0; transition:opacity .4s ease;
  }
  .pv-browser[data-phase="0"] .pv-analysis{ opacity:1; }

  .pv-analysis::before{                    /* Analyse-Spinner */
    content:""; width:44px; height:44px; border-radius:50%;
    border:3px solid rgba(3,105,161,.22);
    border-top-color:var(--pv-blue);
    animation:pv-spin 1s linear infinite;
  }
  .pv-analysis::after{                     /* blinkender Cursor */
    content:""; width:2px; height:28px; background:var(--pv-blue);
    animation:pv-blink 1.05s steps(1) infinite;
  }

  /* ====================================================================
     WIREFRAMES — Grundzustand (versteckt, gestrichelt)
     ==================================================================== */
  .pv-wire{
    position:absolute; z-index:2;
    border:1.5px dashed var(--pv-wire);
    border-radius:7px;
    background:transparent;
    opacity:0; transform:translateY(10px);
    transition:opacity .45s ease, transform .45s ease,
               background-color .55s ease, border-color .45s ease;
  }

  /* Layout des Mini-Layouts */
  .pv-wire-nav{ top:5%;  left:4%;  right:4%;  height:9%;  border-radius:8px; }
  .pv-wire-h1 { top:19%; left:4%;  width:50%; height:21%; overflow:hidden; }
  .pv-wire-h2 { top:43%; left:4%;  width:38%; height:5.5%; }
  .pv-wire-btn{ top:52%; left:4%;  width:26%; height:9.5%; border-radius:9px; }
  .pv-wire-img{ top:20%; right:4%; width:36%; height:36%; overflow:hidden; }
  .pv-wire-c1 { top:67%; left:4%;  width:28.6%; height:26%; }
  .pv-wire-c2 { top:67%; left:35.7%;width:28.6%; height:26%; }
  .pv-wire-c3 { top:67%; left:67.4%;width:28.6%; height:26%; }

  /* ====================================================================
     PHASE 1 — Wireframes erscheinen nacheinander (gestaffelt)
     ==================================================================== */
  .pv-browser[data-phase="1"] .pv-wire,
  .pv-browser[data-phase="2"] .pv-wire,
  .pv-browser[data-phase="3"] .pv-wire,
  .pv-browser[data-phase="4"] .pv-wire,
  .pv-browser[data-phase="5"] .pv-wire{
    opacity:1; transform:translateY(0);
  }
  /* Eintritts-Staffelung: Nav → Hero → Content-Blöcke */
  .pv-wire-nav{ transition-delay:.05s; }
  .pv-wire-h1 { transition-delay:.18s; }
  .pv-wire-h2 { transition-delay:.28s; }
  .pv-wire-img{ transition-delay:.38s; }
  .pv-wire-btn{ transition-delay:.48s; }
  .pv-wire-c1 { transition-delay:.62s; }
  .pv-wire-c2 { transition-delay:.74s; }
  .pv-wire-c3 { transition-delay:.86s; }
  /* ab Phase 2 keine Verzögerung mehr beim Umfärben */
  .pv-browser[data-phase="2"] .pv-wire,
  .pv-browser[data-phase="3"] .pv-wire,
  .pv-browser[data-phase="4"] .pv-wire,
  .pv-browser[data-phase="5"] .pv-wire{ transition-delay:0s; }

  /* ====================================================================
     PHASE 2 — Wireframes füllen sich mit Farbe + Bild-Shimmer
     ==================================================================== */
  .pv-browser[data-phase="2"] .pv-wire,
  .pv-browser[data-phase="3"] .pv-wire,
  .pv-browser[data-phase="4"] .pv-wire,
  .pv-browser[data-phase="5"] .pv-wire{
    border-style:solid; border-color:transparent;
  }
  /* blaue Navigation */
  .pv-browser[data-phase="2"] .pv-wire-nav,
  .pv-browser[data-phase="3"] .pv-wire-nav,
  .pv-browser[data-phase="4"] .pv-wire-nav,
  .pv-browser[data-phase="5"] .pv-wire-nav{ background:var(--pv-blue); }
  /* Skeleton-Füllung der Textblöcke */
  .pv-browser[data-phase="2"] .pv-wire-h1,
  .pv-browser[data-phase="2"] .pv-wire-h2,
  .pv-browser[data-phase="2"] .pv-wire-btn,
  .pv-browser[data-phase="2"] .pv-wire-c1,
  .pv-browser[data-phase="2"] .pv-wire-c2,
  .pv-browser[data-phase="2"] .pv-wire-c3,
  .pv-browser[data-phase="3"] .pv-wire-h2,
  .pv-browser[data-phase="3"] .pv-wire-c1,
  .pv-browser[data-phase="3"] .pv-wire-c2,
  .pv-browser[data-phase="3"] .pv-wire-c3,
  .pv-browser[data-phase="4"] .pv-wire-h2,
  .pv-browser[data-phase="4"] .pv-wire-c1,
  .pv-browser[data-phase="4"] .pv-wire-c2,
  .pv-browser[data-phase="4"] .pv-wire-c3,
  .pv-browser[data-phase="5"] .pv-wire-h2,
  .pv-browser[data-phase="5"] .pv-wire-c1,
  .pv-browser[data-phase="5"] .pv-wire-c2,
  .pv-browser[data-phase="5"] .pv-wire-c3{ background:var(--pv-skel); }

  /* Bild-Platzhalter: Gradient-Shimmer */
  .pv-browser[data-phase="2"] .pv-wire-img,
  .pv-browser[data-phase="3"] .pv-wire-img,
  .pv-browser[data-phase="4"] .pv-wire-img,
  .pv-browser[data-phase="5"] .pv-wire-img{
    background-image:linear-gradient(110deg,
       #1e3a5f 0%, #2d4f73 18%, #3f78b0 38%, #2d4f73 58%, #1e3a5f 80%);
    background-size:220% 100%;
    animation:pv-shimmer 1.9s linear infinite;
  }

  .pv-wire-img::before,
  .pv-wire-img::after{
    content:"";
    position:absolute;
    opacity:0;
    transition:opacity .45s ease, transform .45s ease;
  }

  .pv-browser[data-phase="4"] .pv-wire-img,
  .pv-browser[data-phase="5"] .pv-wire-img{
    background:
      linear-gradient(180deg,#70c7ff 0 46%,#0f766e 47% 62%,#f7d08a 63% 100%);
    animation:none;
  }

  .pv-browser[data-phase="4"] .pv-wire-img::before,
  .pv-browser[data-phase="5"] .pv-wire-img::before{
    left:9%;
    right:9%;
    bottom:14%;
    height:26%;
    border-radius:999px 999px 8px 8px;
    background:
      radial-gradient(circle at 18% 45%,#14532d 0 16%,transparent 17%),
      radial-gradient(circle at 47% 35%,#166534 0 18%,transparent 19%),
      radial-gradient(circle at 78% 48%,#15803d 0 15%,transparent 16%),
      linear-gradient(180deg,#22c55e,#15803d);
    opacity:1;
    transform:translateY(0);
  }

  .pv-browser[data-phase="4"] .pv-wire-img::after,
  .pv-browser[data-phase="5"] .pv-wire-img::after{
    width:24px;
    height:24px;
    right:11%;
    top:13%;
    border-radius:50%;
    background:#fbbf24;
    box-shadow:0 0 26px rgba(251,191,36,.65);
    opacity:1;
    transform:scale(1);
  }

  /* Content-Blöcke: Thumbnail (::before) + Textzeilen (::after) ab Phase 2 */
  .pv-wire-c1::before,.pv-wire-c2::before,.pv-wire-c3::before{
    content:""; position:absolute; inset:9% 9% 56% 9%; border-radius:5px;
    background:linear-gradient(135deg,#1e3a5f,#3f78b0);
    opacity:0; transition:opacity .5s ease;
  }
  .pv-wire-c1::after,.pv-wire-c2::after,.pv-wire-c3::after{
    content:""; position:absolute; left:9%; right:9%; top:50%; height:34%;
    background:
      linear-gradient(var(--pv-wire) 0 0) left  0%/100% 16% no-repeat,
      linear-gradient(var(--pv-wire) 0 0) left 42%/82% 16% no-repeat,
      linear-gradient(var(--pv-wire) 0 0) left 84%/58% 16% no-repeat;
    opacity:0; transition:opacity .5s ease;
  }
  .pv-browser[data-phase="2"] .pv-wire-c1::before,.pv-browser[data-phase="2"] .pv-wire-c1::after,
  .pv-browser[data-phase="2"] .pv-wire-c2::before,.pv-browser[data-phase="2"] .pv-wire-c2::after,
  .pv-browser[data-phase="2"] .pv-wire-c3::before,.pv-browser[data-phase="2"] .pv-wire-c3::after,
  .pv-browser[data-phase="3"] .pv-wire-c1::before,.pv-browser[data-phase="3"] .pv-wire-c1::after,
  .pv-browser[data-phase="3"] .pv-wire-c2::before,.pv-browser[data-phase="3"] .pv-wire-c2::after,
  .pv-browser[data-phase="3"] .pv-wire-c3::before,.pv-browser[data-phase="3"] .pv-wire-c3::after,
  .pv-browser[data-phase="4"] .pv-wire-c1::before,.pv-browser[data-phase="4"] .pv-wire-c1::after,
  .pv-browser[data-phase="4"] .pv-wire-c2::before,.pv-browser[data-phase="4"] .pv-wire-c2::after,
  .pv-browser[data-phase="4"] .pv-wire-c3::before,.pv-browser[data-phase="4"] .pv-wire-c3::after,
  .pv-browser[data-phase="5"] .pv-wire-c1::before,.pv-browser[data-phase="5"] .pv-wire-c1::after,
  .pv-browser[data-phase="5"] .pv-wire-c2::before,.pv-browser[data-phase="5"] .pv-wire-c2::after,
  .pv-browser[data-phase="5"] .pv-wire-c3::before,.pv-browser[data-phase="5"] .pv-wire-c3::after{ opacity:1; }

  .pv-browser[data-phase="4"] .pv-wire-c1,
  .pv-browser[data-phase="4"] .pv-wire-c2,
  .pv-browser[data-phase="4"] .pv-wire-c3,
  .pv-browser[data-phase="5"] .pv-wire-c1,
  .pv-browser[data-phase="5"] .pv-wire-c2,
  .pv-browser[data-phase="5"] .pv-wire-c3{
    background:#334155;
  }

  .pv-browser[data-phase="4"] .pv-wire-c1::before,
  .pv-browser[data-phase="4"] .pv-wire-c2::before,
  .pv-browser[data-phase="4"] .pv-wire-c3::before,
  .pv-browser[data-phase="5"] .pv-wire-c1::before,
  .pv-browser[data-phase="5"] .pv-wire-c2::before,
  .pv-browser[data-phase="5"] .pv-wire-c3::before{
    inset:8% 9% 60% 9%;
    background:
      linear-gradient(135deg,rgba(255,255,255,.16),transparent 45%),
      linear-gradient(135deg,#0369a1,#38bdf8);
  }

  .pv-browser[data-phase="4"] .pv-wire-c1::after,
  .pv-browser[data-phase="5"] .pv-wire-c1::after{
    content:"Konzept\A Struktur, Zielgruppe und klare Botschaft.";
  }

  .pv-browser[data-phase="4"] .pv-wire-c2::after,
  .pv-browser[data-phase="5"] .pv-wire-c2::after{
    content:"Design\A Farben, Bilder und Layout passend zur Marke.";
  }

  .pv-browser[data-phase="4"] .pv-wire-c3::after,
  .pv-browser[data-phase="5"] .pv-wire-c3::after{
    content:"Launch\A Fertige Website online und mobil optimiert.";
  }

  .pv-browser[data-phase="4"] .pv-wire-c1::after,
  .pv-browser[data-phase="4"] .pv-wire-c2::after,
  .pv-browser[data-phase="4"] .pv-wire-c3::after,
  .pv-browser[data-phase="5"] .pv-wire-c1::after,
  .pv-browser[data-phase="5"] .pv-wire-c2::after,
  .pv-browser[data-phase="5"] .pv-wire-c3::after{
    top:50%;
    height:auto;
    background:none;
    white-space:pre-line;
    font:700 1.55cqw/1.35 'Inter',sans-serif;
    color:#e2e8f0;
  }

  /* Titel-Text (Skeleton-Bar in Phase 2, getippt ab Phase 3) */
  .pv-wire-h1::before,
  .pv-wire-h1::after{
    position:absolute;
    left:14px;
    display:block;
    width:0;
    white-space:nowrap;
    overflow:hidden;
    font:800 6.1cqw/1 'Inter',sans-serif;
    color:var(--pv-ink);
    border-right:2px solid transparent;
  }

  .pv-wire-h1::before{
    content:"Ihre perfekte";
    top:10%;
  }

  .pv-wire-h1::after{
    content:"Website.";
    top:55%;
  }

  /* ====================================================================
     PHASE 3 — Typewriter auf dem Titel + Buttons poppen rein
     ==================================================================== */
  .pv-browser[data-phase="3"] .pv-wire-h1,
  .pv-browser[data-phase="4"] .pv-wire-h1,
  .pv-browser[data-phase="5"] .pv-wire-h1{ background:transparent; }

  .pv-browser[data-phase="3"] .pv-wire-h1::before,
  .pv-browser[data-phase="4"] .pv-wire-h1::before,
  .pv-browser[data-phase="5"] .pv-wire-h1::before{
    width:13ch;
    border-right-color:var(--pv-blue);
    animation:pv-type 1s steps(13,end) forwards;
  }

  .pv-browser[data-phase="3"] .pv-wire-h1::after,
  .pv-browser[data-phase="4"] .pv-wire-h1::after,
  .pv-browser[data-phase="5"] .pv-wire-h1::after{
    width:8ch;
    border-right-color:var(--pv-blue);
    animation:pv-type-website .7s steps(8,end) .9s both, pv-caret .7s steps(1) 1s infinite;
  }

  /* Button füllt sich grün + Pop, Label erscheint */
  .pv-wire-btn::after{
    content:"Jetzt starten"; position:absolute; inset:0;
    display:flex; align-items:center; justify-content:center;
    font:700 4cqw/1 'Inter',sans-serif; color:#04210f;
    opacity:0; transition:opacity .3s ease .15s;
  }
  .pv-browser[data-phase="3"] .pv-wire-btn,
  .pv-browser[data-phase="4"] .pv-wire-btn,
  .pv-browser[data-phase="5"] .pv-wire-btn{
    background:var(--pv-green);
    animation:pv-pop .5s cubic-bezier(.34,1.56,.64,1) both;
  }
  .pv-browser[data-phase="3"] .pv-wire-btn::after,
  .pv-browser[data-phase="4"] .pv-wire-btn::after,
  .pv-browser[data-phase="5"] .pv-wire-btn::after{ opacity:1; }

  /* ====================================================================
     PHASE 4 — fertige Seite, pulsierendes "LIVE"-Badge
     ==================================================================== */
  .pv-live-badge{
    position:absolute; top:10px; right:10px; z-index:7;
    display:inline-flex; align-items:center; gap:5px;
    padding:4px 11px; border-radius:999px;
    background:var(--pv-green); color:#04210f;
    font:800 11px/1 'Inter',sans-serif; letter-spacing:.6px;
    opacity:0; transform:scale(.5); transform-origin:top right;
    transition:opacity .35s ease, transform .35s cubic-bezier(.34,1.56,.64,1);
  }
  .pv-browser[data-phase="4"] .pv-live-badge,
  .pv-browser[data-phase="5"] .pv-live-badge{
    opacity:1; transform:scale(1);
    animation:pv-pulse 1.7s ease-in-out infinite .35s;
  }

  /* ====================================================================
     PHASE 5 — Done-Overlay + Konfetti
     ==================================================================== */
  .pv-done{
    position:absolute; inset:0; z-index:10;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:10px; text-align:center;
    background:rgba(15,23,42,.94);
    -webkit-backdrop-filter:blur(3px); backdrop-filter:blur(3px);
    opacity:0; visibility:hidden;
    transition:opacity .5s ease, visibility .5s ease;
  }
  .pv-browser[data-phase="5"] .pv-done{ opacity:1; visibility:visible; }

  .pv-done-check{
    width:66px; height:66px; border-radius:50%;
    background:var(--pv-green); color:#04210f;
    display:flex; align-items:center; justify-content:center;
    font-size:36px; font-weight:900; line-height:1;
    transform:scale(0);
    box-shadow:0 0 0 0 rgba(34,197,94,.45);
  }
  .pv-browser[data-phase="5"] .pv-done-check{
    animation:pv-check-pop .6s cubic-bezier(.34,1.6,.5,1) .15s both,
              pv-pulse 1.7s ease-in-out 1.1s infinite;
  }
  .pv-done strong{ font:700 19px/1.2 'Inter',sans-serif; color:var(--pv-ink); }
  .pv-done span  { font:500 14px/1.2 'Inter',sans-serif; color:#94a3b8; }

  /* Konfetti — zwei Pseudo-Ebenen mit gestreuten box-shadow-Punkten */
  .pv-done::before,.pv-done::after{
    content:""; position:absolute; top:-6%; left:0; z-index:11;
    width:7px; height:7px; border-radius:1px;
    opacity:0;
  }
  .pv-browser[data-phase="5"] .pv-done::before{
    animation:pv-confetti 1.7s ease-in .25s both;
    box-shadow:
       8cqw  1cqw var(--pv-green), 16cqw 4cqw var(--pv-blue),
      24cqw  0    #fbbf24,        33cqw 5cqw var(--pv-green),
      41cqw  2cqw #ffffff,        50cqw 6cqw var(--pv-blue),
      58cqw  1cqw var(--pv-green),67cqw 4cqw #fbbf24,
      75cqw  0    var(--pv-blue), 84cqw 5cqw var(--pv-green),
      92cqw  2cqw #ffffff;
  }
  .pv-browser[data-phase="5"] .pv-done::after{
    animation:pv-confetti 1.9s ease-in .42s both;
    box-shadow:
      12cqw 6cqw #ffffff,        21cqw 2cqw var(--pv-green),
      29cqw 4cqw var(--pv-blue), 38cqw 0    #fbbf24,
      47cqw 5cqw var(--pv-green),55cqw 1cqw #ffffff,
      63cqw 4cqw var(--pv-blue), 72cqw 6cqw var(--pv-green),
      80cqw 2cqw #fbbf24,        89cqw 4cqw var(--pv-blue);
  }

  /* ---------- Keyframes ---------- */
  @keyframes pv-spin   { to{ transform:rotate(360deg); } }
  @keyframes pv-blink  { 0%,48%{ opacity:1; } 52%,100%{ opacity:0; } }
  @keyframes pv-shimmer{ to{ background-position:-220% 0; } }
  @keyframes pv-type   { from{ width:0; } to{ width:13ch; } }
  @keyframes pv-type-website{ from{ width:0; } to{ width:8ch; } }
  @keyframes pv-caret  { 0%,100%{ border-right-color:var(--pv-blue); } 50%{ border-right-color:transparent; } }
  @keyframes pv-pop    { 0%{ transform:scale(0); } 100%{ transform:scale(1); } }
  @keyframes pv-pulse  { 0%,100%{ box-shadow:0 0 0 0 rgba(34,197,94,.5); } 50%{ box-shadow:0 0 0 9px rgba(34,197,94,0); } }
  @keyframes pv-check-pop{ 0%{ transform:scale(0) rotate(-25deg); } 100%{ transform:scale(1) rotate(0); } }
  @keyframes pv-confetti{
    0%  { opacity:0; transform:translateY(-8cqw)  rotate(0deg); }
    12% { opacity:1; }
    100%{ opacity:0; transform:translateY(78cqw) rotate(35deg); }
  }

  .pv-caption {
    text-align: center;
    margin-top: 1rem;
    color: #93C5FD;
    font-size: 0.9rem;
    font-weight: 500;
    min-height: 1.4em;
    transition: color 0.3s ease;
  }

  .process-cta {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    text-align: center;
  }
  .process-cta p { color: #CBD5E1; margin: 0; font-size: 1.05rem; }

  @media (prefers-reduced-motion: reduce) {
    .process-step { opacity: 1; }
    .process-step .step-number { opacity: 1; }
    .pv-browser *,
    .pv-browser *::before,
    .pv-browser *::after {
      animation: none !important;
      transition-duration: .001ms !important;
    }
    .pv-browser[data-phase="3"] .pv-wire-h1::before,
    .pv-browser[data-phase="4"] .pv-wire-h1::before,
