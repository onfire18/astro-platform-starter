  }
  @keyframes floatbob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes floatcard {
    0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-6px) rotate(var(--rot, 0deg)); }
  }
  .animate-fadeinup {
    opacity: 0;
    animation: fadeinup 0.7s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .animate-delay-1 { animation-delay: 0.15s; }
  .animate-delay-2 { animation-delay: 0.3s; }
  .animate-floatup {
    opacity: 0;
    animation: fadeinup 0.6s cubic-bezier(0.22,1,0.36,1) forwards, floatcard 4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fadeinup, .animate-floatup { animation: none; opacity: 1; }
  }

  /* ---- Hero ---- */
  .hero {
    background:
      radial-gradient(ellipse 80% 55% at 72% 38%, rgba(186,219,255,0.5) 0%, transparent 65%),
