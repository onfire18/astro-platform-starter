<script>
  // ---- Industry Tabs ----
  (function () {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.industry-tab');
    const panels = document.querySelectorAll<HTMLElement>('.industry-panel');

    function activate(id: string) {
      tabs.forEach(tab => {
        const isActive = tab.dataset.industry === id;
        tab.classList.toggle('active', isActive);
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      panels.forEach(panel => {
        const isActive = panel.id === `panel-${id}`;
        panel.classList.toggle('active', isActive);
        panel.hidden = !isActive;
      });
    }

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        activate(tab.dataset.industry ?? '');
      });
      tab.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'ArrowRight' || e.key === 'ArrowLeft') {
          e.preventDefault();
          const tabsArr = Array.from(tabs);
          const idx = tabsArr.indexOf(tab);
          const next = e.key === 'ArrowRight'
            ? (idx + 1) % tabsArr.length
            : (idx - 1 + tabsArr.length) % tabsArr.length;
          tabsArr[next].focus();
          activate(tabsArr[next].dataset.industry ?? '');
        }
      });
    });
  })();

  // ---- Contact Form ----
  (function () {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
    const successEl = document.getElementById('form-success') as HTMLElement | null;
    const errorEl = document.getElementById('form-error') as HTMLElement | null;

    if (!form) return;

    function showMessage(el: HTMLElement | null) {
      if (!el) return;
      el.hidden = false;
      el.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }

    function validate(): boolean {
      const name = (form!.elements.namedItem('name') as HTMLInputElement)?.value.trim();
      const email = (form!.elements.namedItem('email') as HTMLInputElement)?.value.trim();

      if (!name) {
        const nameField = document.getElementById('field-name') as HTMLInputElement;
        nameField?.focus();
        nameField?.setCustomValidity('Bitte geben Sie Ihren Namen an.');
        nameField?.reportValidity();
        return false;
      }
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        const emailField = document.getElementById('field-email') as HTMLInputElement;
        emailField?.focus();
        emailField?.setCustomValidity('Bitte geben Sie eine gültige E-Mail-Adresse an.');
        emailField?.reportValidity();
        return false;
      }
      return true;
    }

    // Rate limiting: max 3 Versuche pro Session, 60s Cooldown nach Erfolg
    let submitCount = 0;
    let lastSubmitTime = 0;
    const MAX_ATTEMPTS = 3;
    const COOLDOWN_MS = 60_000;

    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      if (!validate()) return;

      const now = Date.now();
      if (submitCount >= MAX_ATTEMPTS && now - lastSubmitTime < COOLDOWN_MS) {
        if (errorEl) {
          errorEl.textContent = 'Zu viele Versuche. Bitte warten Sie eine Minute.';
          showMessage(errorEl);
        }
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet…';
      }
      if (successEl) successEl.hidden = true;
      if (errorEl) errorEl.hidden = true;

      try {
        const data = new FormData(form);
        const response = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as unknown as Record<string, string>).toString(),
        });

        if (response.ok) {
          form.reset();
          showMessage(successEl);
          submitCount = 0; // Reset nach Erfolg
          // Nach Erfolg: Button 60s deaktiviert lassen
          lastSubmitTime = Date.now();
          setTimeout(() => {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = 'Entwurf anfragen';
            }
          }, COOLDOWN_MS);
        } else {
          throw new Error(`HTTP ${response.status}`);
        }
      } catch {
        showMessage(errorEl);
        submitCount++;
        lastSubmitTime = Date.now();
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Entwurf anfragen';
        }
      }
    });

    // Clear custom validity on input
    form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>('.form-input').forEach(field => {
      field.addEventListener('input', () => field.setCustomValidity(''));
    });
  })();

  // ---- Hero mockup slider ----
  (function () {
    const slides = document.querySelectorAll<HTMLElement>('.mock-slide');
    const dots = document.querySelectorAll<HTMLButtonElement>('.sdot');
    const urlEl = document.getElementById('mock-url-text');
    if (!slides.length) return;

    let current = 0;
    let timer: ReturnType<typeof setInterval>;

    function goTo(n: number) {
      slides[current].classList.remove('active');
      dots[current]?.classList.remove('active');
      current = (n + slides.length) % slides.length;
      slides[current].classList.add('active');
      dots[current]?.classList.add('active');
      if (urlEl) urlEl.textContent = (slides[current] as HTMLElement).dataset.url ?? '';
    }

    function startTimer() {
      clearInterval(timer);
      timer = setInterval(() => goTo(current + 1), 3500);
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => { goTo(i); startTimer(); });
    });

    const wrap = document.querySelector('.mockup-slider-wrap');
    if (wrap) {
      wrap.addEventListener('mouseenter', () => clearInterval(timer));
      wrap.addEventListener('mouseleave', startTimer);
    }

    startTimer();
  })();

  // ---- Process build-up animation ----
  (function () {
    const section = document.querySelector('.process-section');
    const steps = Array.from(document.querySelectorAll<HTMLElement>('.process-step'));
    const browser = document.getElementById('pv-browser');
    const caption = document.getElementById('pv-caption');
    if (!section || !steps.length || !browser) return;

    const captions = [
      'Erstgespräch & Analyse',
      'Konzept & Design',
      'Entwicklung',
      'Launch & Übergabe',
      'Support – Ihre Website ist fertig!',
    ];

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let played = false;
    let timers: ReturnType<typeof setTimeout>[] = [];

    function clearTimers() { timers.forEach(clearTimeout); timers = []; }

    function setStep(i: number) {
      steps.forEach((step, idx) => {
        step.classList.toggle('is-active', idx === i);
        step.classList.toggle('is-done', idx < i);
      });
      browser!.setAttribute('data-phase', String(i + 1));
      if (caption) caption.textContent = captions[i] ?? '';
    }

    function play() {
      if (played) return;
      played = true;
      clearTimers();
      if (reduce) { setStep(steps.length - 1); return; }
      browser!.setAttribute('data-phase', '0');
      steps.forEach((s) => s.classList.remove('is-active', 'is-done'));
      steps.forEach((_, i) => {
        timers.push(setTimeout(() => setStep(i), 700 + i * 1400));
      });
    }

    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) { play(); io.unobserve(entry.target); }
        });
      },
      { threshold: 0.35 }
    );
    io.observe(section);
  })();

  // ---- Floating contact button ----
  (function () {
    const btn = document.getElementById('floating-contact');
    const hero = document.querySelector('.hero');
    const contact = document.getElementById('kontakt');
    if (!btn) return;

    let pastHero = false;
    let atContact = false;

    function update() {
      btn!.classList.toggle('is-visible', pastHero && !atContact);
    }

    if (hero) {
      new IntersectionObserver(
        (entries) => { pastHero = !entries[0].isIntersecting; update(); },
        { threshold: 0 }
      ).observe(hero);
    } else {
      pastHero = true;
    }

    if (contact) {
      new IntersectionObserver(
        (entries) => { atContact = entries[0].isIntersecting; update(); },
        { threshold: 0.1 }
      ).observe(contact);
    }
  })();

  // ---- Intro overlay (einmal pro Session) ----
  (function () {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const intro = document.getElementById('intro');
    const hero = document.querySelector('.hero-intro');
    const seen = sessionStorage.getItem('md-intro-seen');

    const showHero = () => hero?.classList.add('is-in');

    if (reduce || seen || !intro) {
      intro?.classList.add('is-done');
      showHero();
      return;
    }

    sessionStorage.setItem('md-intro-seen', '1');
    intro.classList.add('is-playing');
    // Logo 0→1 (400ms) + halten (300ms) → Overlay 1→0 (500ms), Hero gleitet rein
    window.setTimeout(() => { intro.classList.add('is-leaving'); showHero(); }, 700);
    window.setTimeout(() => intro.classList.add('is-done'), 1200);
  })();
</script>
