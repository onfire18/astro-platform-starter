  <section id="kontakt" class="md-section contact-section" aria-labelledby="contact-headline">
    <div class="md-container contact-inner">
      <div class="contact-header">
        <span class="md-label">Kontakt</span>
        <h2 id="contact-headline">Unverbindlichen Entwurf anfragen</h2>
        <p>
          Schildern Sie kurz, was Sie sich vorstellen. Wir melden uns innerhalb eines
          Werktages mit einem ersten Eindruck.
        </p>
        <div class="contact-alternatives">
          <a href={waCustomer} class="md-btn md-btn-outline whatsapp-btn" target="_blank" rel="noopener noreferrer" aria-label="Per WhatsApp kontaktieren">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            WhatsApp
          </a>
          <a href={`tel:${SITE.contact.phone}`} class="md-btn md-btn-outline" aria-label={`Anrufen: ${SITE.contact.phone}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.63A2 2 0 012 1.08h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/>
            </svg>
            {SITE.contact.phone}
          </a>
        </div>
      </div>

      <form
        id="contact-form"
        name="kontakt"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form md-card"
        novalidate
        aria-label="Kontaktformular"
      >
        <input type="hidden" name="form-name" value="kontakt" />
        <p hidden>
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="field-name" class="form-label">Name <span aria-label="Pflichtfeld">*</span></label>
            <input type="text" id="field-name" name="name" class="form-input" required autocomplete="name" placeholder="Ihr vollständiger Name" aria-required="true" />
          </div>
          <div class="form-group">
            <label for="field-company" class="form-label">Unternehmen</label>
            <input type="text" id="field-company" name="unternehmen" class="form-input" autocomplete="organization" placeholder="Ihr Unternehmensname (optional)" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="field-email" class="form-label">E-Mail <span aria-label="Pflichtfeld">*</span></label>
            <input type="email" id="field-email" name="email" class="form-input" required autocomplete="email" placeholder="ihre@email.de" aria-required="true" />
          </div>
          <div class="form-group">
            <label for="field-phone" class="form-label">Telefon / WhatsApp</label>
            <input type="tel" id="field-phone" name="telefon" class="form-input" autocomplete="tel" placeholder="Optional – für Rückruf" />
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="field-branche" class="form-label">Branche</label>
            <select id="field-branche" name="branche" class="form-input">
              <option value="">Bitte wählen (optional)</option>
              <option>Kanzlei / Rechtsanwalt</option>
              <option>Handwerk / Baugewerbe</option>
              <option>Immobilien</option>
              <option>Gastronomie / Café</option>
              <option>Beratung / Coaching</option>
              <option>Arzt / Praxis</option>
              <option>Fitness / Wellness</option>
              <option>Autohaus / KFZ</option>
              <option>Lokaler Dienstleister</option>
              <option>Sonstiges</option>
            </select>
          </div>
          <div class="form-group">
            <label for="field-leistung" class="form-label">Gewünschte Leistung</label>
            <select id="field-leistung" name="leistung" class="form-input">
              <option value="">Bitte wählen (optional)</option>
              <option>Neue Website</option>
              <option>Website-Redesign</option>
              <option>SEO-Optimierung</option>
              <option>Google Ads / Marketing</option>
              <option>Betreuung / Wartung</option>
              <option>Ich bin noch unsicher</option>
            </select>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="field-existing" class="form-label">Bestehende Website</label>
            <input type="url" id="field-existing" name="bestehende_website" class="form-input" placeholder="https://ihre-website.de (optional)" />
          </div>
          <div class="form-group">
            <label for="field-contact-pref" class="form-label">Bevorzugter Kontaktweg</label>
            <select id="field-contact-pref" name="kontaktweg" class="form-input">
              <option value="">Egal / Beides</option>
              <option>E-Mail</option>
              <option>Telefon / Rückruf</option>
              <option>WhatsApp</option>
              <option>Video-Call</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <label for="field-message" class="form-label">Projektbeschreibung</label>
          <textarea id="field-message" name="nachricht" class="form-input form-textarea" rows="4" placeholder="Was macht Ihr Unternehmen aus? Wen möchten Sie erreichen? Was soll die Website leisten?"></textarea>
        </div>

        <div class="form-group form-consent">
          <label class="consent-label">
            <input type="checkbox" name="datenschutz" required aria-required="true" id="field-consent" />
            <span>Ich habe die <a href="/datenschutz">Datenschutzerklärung</a> gelesen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu. <span aria-label="Pflichtfeld">*</span></span>
          </label>
        </div>

        <div class="form-footer">
          <button type="submit" class="md-btn md-btn-primary form-submit" id="submit-btn">
            Entwurf erstellen lassen
          </button>
          <p class="form-required-note"><span aria-label="Pflichtfeld">*</span> Pflichtfelder</p>
        </div>

        <div id="form-success" class="form-success" hidden aria-live="polite">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="#22C55E" stroke-width="2"/>
            <path d="M8 12l3 3 5-5" stroke="#22C55E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <div>
            <strong>Anfrage erhalten!</strong>
            <p>Wir melden uns innerhalb eines Werktages bei Ihnen. Vielen Dank.</p>
          </div>
        </div>

        <div id="form-error" class="form-error" hidden aria-live="polite">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="12" cy="12" r="10" stroke="#EF4444" stroke-width="2"/>
            <path d="M12 8v4M12 16h.01" stroke="#EF4444" stroke-width="2" stroke-linecap="round"/>
          </svg>
          <div>
            <strong>Etwas ist schiefgelaufen.</strong>
            <p>Bitte versuchen Sie es erneut oder schreiben Sie uns per WhatsApp.</p>
          </div>
        </div>
      </form>
    </div>
  </section>

</MDLayout>

<!-- =========================================================
     STYLES
========================================================== -->
<style>
  /* ---- Animations ---- */
  @keyframes fadeinup {
    from { opacity: 0; transform: translateY(28px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes floatbob {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }
  @keyframes floatcard {
    0%, 100% { transform: translateY(0) rotate(var(--rot, 0deg)); }
    50%       { transform: translateY(-6px) rotate(var(--rot, 0deg)); }
  }
  .animate-fadeinup {
    opacity: 0;
    animation: fadeinup 0.7s cubic-bezier(0.22,1,0.36,1) forwards;
  }
  .animate-delay-1 { animation-delay: 0.15s; }
  .animate-delay-2 { animation-delay: 0.3s; }
  .animate-floatup {
    opacity: 0;
    animation: fadeinup 0.6s cubic-bezier(0.22,1,0.36,1) forwards, floatcard 4s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .animate-fadeinup, .animate-floatup { animation: none; opacity: 1; }
  }

  /* ---- Hero ---- */
  .hero {
    background: linear-gradient(160deg, #F8FAFC 60%, #EFF6FF 100%);
    padding-top: calc(var(--nav-h) + 3rem);
    padding-bottom: 4rem;
    overflow: hidden;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 4rem;
    align-items: center;
  }
  .hero-label {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--md-cta);
    background: var(--md-accent);
    padding: 0.3rem 0.75rem;
    border-radius: 99px;
    margin-bottom: 1.25rem;
  }
  .hero-h1 {
    font-family: 'DM Serif Display', Georgia, serif;
    font-size: clamp(2.2rem, 4.5vw, 3.5rem);
    font-weight: 400;
    line-height: 1.12;
    color: var(--md-primary);
    margin-bottom: 1.5rem;
  }
  .hero-highlight { color: var(--md-cta); }
  .hero-sub {
    font-size: 1.05rem;
    color: var(--md-secondary);
    line-height: 1.7;
    max-width: 42ch;
    margin-bottom: 2.25rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.25rem; }
  .hero-btn-primary { display: flex; align-items: center; gap: 0.5rem; }
  .hero-sales-hint { font-size: 0.88rem; color: var(--md-muted); }
  .hero-sales-hint a { color: var(--md-cta); text-decoration: underline; font-weight: 500; }

  /* ---- Mockup ---- */
  .hero-visual { position: relative; }
  .hero-mockup-wrap {
    position: relative;
    animation: floatbob 5s ease-in-out infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-mockup-wrap { animation: none; }
  }

  .mock-browser {
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 24px 80px rgba(15,23,42,0.15), 0 4px 16px rgba(15,23,42,0.08);
    overflow: hidden;
    border: 1px solid #E2E8F0;
  }
  .mock-chrome {
    background: #F1F5F9;
    border-bottom: 1px solid #E2E8F0;
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .mock-dots { display: flex; gap: 5px; }
  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot-r { background: #EF4444; }
  .dot-y { background: #F59E0B; }
  .dot-g { background: #22C55E; }
  .mock-url {
    flex: 1;
    background: #fff;
    border: 1px solid #E2E8F0;
    border-radius: 6px;
    padding: 0.25rem 0.6rem;
    font-size: 0.72rem;
    color: #64748B;
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .mock-body { padding: 0; }

  /* Inner nav */
  .mock-inner-nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 0.6rem 1.25rem;
    border-bottom: 1px solid #F1F5F9;
  }
  .mock-inner-logo { display: flex; align-items: center; gap: 0.4rem; }
  .mock-inner-logo-mark { width: 16px; height: 16px; background: #0369A1; border-radius: 3px; }
  .mock-inner-logo-text { width: 50px; height: 7px; background: #0F172A; border-radius: 2px; }
  .mock-inner-links { display: flex; gap: 0.75rem; flex: 1; }
  .mock-inner-links span { font-size: 0.62rem; color: #64748B; }
  .mock-inner-cta {
    background: #0369A1;
    color: #fff;
    font-size: 0.6rem;
    padding: 0.3rem 0.65rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  /* Mock hero content */
  .mock-hero-content {
    display: grid;
    grid-template-columns: 1fr 0.85fr;
    gap: 1rem;
    padding: 1.25rem 1.25rem 0.75rem;
    background: linear-gradient(135deg, #F8FAFC 0%, #EFF6FF 100%);
  }
  .mock-hl { height: 10px; background: #0F172A; border-radius: 3px; margin-bottom: 6px; }
  .mock-hl-1 { width: 90%; }
  .mock-hl-2 { width: 75%; }
  .mock-hl-3 { width: 60%; background: #0369A1; }
  .mock-sl { height: 6px; background: #CBD5E1; border-radius: 2px; margin-bottom: 5px; }
  .mock-sl-1 { width: 100%; }
  .mock-sl-2 { width: 80%; }
  .mock-cta-btn {
    display: inline-block;
    background: #0369A1;
    color: #fff;
    font-size: 0.62rem;
    padding: 0.4rem 0.8rem;
    border-radius: 5px;
    margin-top: 0.5rem;
  }
  .mock-headline-lines { margin-bottom: 0.5rem; }
  .mock-sub-lines { margin-bottom: 0.5rem; }
  .mock-img-placeholder { border-radius: 6px; overflow: hidden; }
  .mock-img-placeholder svg { width: 100%; display: block; }
  .mock-trust-row {
    padding: 0.6rem 1.25rem 0.85rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid #F1F5F9;
  }
  .mock-trust-row > span { font-size: 0.58rem; color: #94A3B8; white-space: nowrap; }
  .mock-logos { display: flex; gap: 0.75rem; }
  .mock-logo-name { font-size: 0.6rem; font-weight: 700; color: #CBD5E1; letter-spacing: 0.05em; }

  /* Floating stat cards */
  .float-card {
    position: absolute;
    background: #fff;
