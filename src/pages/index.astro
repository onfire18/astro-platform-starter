---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Automatisierungen für dein Business" description="AutoFlow – Erstelle professionelle Rechnungen, Angebote und mehr in Sekunden. Kostenlos und ohne Anmeldung.">

    <!-- Hero -->
    <section class="relative py-20 sm:py-28 text-center overflow-hidden">
        <!-- Background glow -->
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            <div class="absolute -top-32 left-1/2 -translate-x-1/2 w-[600px] h-[600px] rounded-full bg-brand-600/20 blur-[120px]"></div>
        </div>

        <div class="relative">
            <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand-600/15 border border-brand-500/30 text-brand-300 text-xs font-medium mb-6">
                <span class="w-1.5 h-1.5 rounded-full bg-brand-400 animate-pulse"></span>
                Jetzt kostenlos verfügbar
            </span>

            <h1 class="text-4xl sm:text-6xl font-bold text-white leading-tight mb-5 tracking-tight">
                Automatisierungen,<br/>
                <span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">die dein Business</span><br/>
                voranbringen.
            </h1>

            <p class="text-neutral-400 text-lg sm:text-xl max-w-2xl mx-auto mb-10 leading-relaxed">
                Professionelle Rechnungen, Angebote und mehr – erstellt in Sekunden.
                Keine Anmeldung, keine Kosten, keine Kompromisse.
            </p>

            <div class="flex flex-col sm:flex-row gap-3 justify-center">
                <a href="/invoice" class="no-underline inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-brand-600 hover:bg-brand-500 text-white font-semibold rounded-xl transition shadow-xl shadow-brand-700/40">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                    Rechnung erstellen
                </a>
                <a href="#features" class="no-underline inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-white/5 hover:bg-white/10 border border-white/10 text-white font-semibold rounded-xl transition">
                    Alle Funktionen
                </a>
            </div>

            <!-- Stats -->
            <div class="flex flex-col sm:flex-row gap-6 sm:gap-12 justify-center mt-14 text-center">
                {[
                    { value: '100%', label: 'Kostenlos' },
                    { value: '0', label: 'Anmeldung nötig' },
                    { value: 'DSGVO', label: 'Konform' },
                ].map(stat => (
                    <div>
                        <div class="text-2xl font-bold text-brand-400">{stat.value}</div>
                        <div class="text-sm text-neutral-500 mt-0.5">{stat.label}</div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-16 sm:py-20 scroll-mt-10">
        <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">Alles was du brauchst</h2>
            <p class="text-neutral-400">Mächtige Werkzeuge für Freelancer und kleine Unternehmen.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

            <!-- Invoice - Available -->
            <a href="/invoice" class="no-underline group relative bg-white/5 hover:bg-white/8 border border-white/10 hover:border-brand-500/40 rounded-2xl p-6 transition">
                <div class="absolute top-4 right-4">
                    <span class="px-2 py-0.5 rounded-full bg-brand-600/20 border border-brand-500/30 text-brand-300 text-xs font-medium">Verfügbar</span>
                </div>
                <div class="w-11 h-11 rounded-xl bg-brand-600/20 border border-brand-500/20 flex items-center justify-center mb-4 group-hover:bg-brand-600/30 transition">
                    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                </div>
                <h3 class="text-base font-semibold text-white mb-1.5">Rechnungsgenerator</h3>
                <p class="text-sm text-neutral-400 leading-relaxed">Professionelle Rechnungen im deutschen Format. Mit MwSt-Berechnung, IBAN und PDF-Download.</p>
            </a>

            <!-- Offer - Coming Soon -->
            {[
                {
                    icon: `<path d="M9 14l-4-4 4-4"/><path d="M5 10h11a4 4 0 0 1 0 8h-1"/>`,
                    title: 'Angebotsgenerator',
                    desc: 'Erstelle professionelle Angebote und wandle sie mit einem Klick in Rechnungen um.',
                },
                {
                    icon: `<path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
                    title: 'Mahnung & Erinnerung',
                    desc: 'Automatisierte Zahlungserinnerungen und Mahnungen mit rechtssicherem Text.',
                },
                {
                    icon: `<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>`,
                    title: 'Zeiterfassung',
                    desc: 'Stunden tracken und automatisch in abrechenbare Rechnungspositionen umwandeln.',
                },
                {
                    icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/>`,
                    title: 'Vertragsvorlagen',
                    desc: 'Rechtssichere Vertragsvorlagen für Freelancer – angepasst auf dein Business.',
                },
                {
                    icon: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>`,
                    title: 'Business Dashboard',
                    desc: 'Behalte Umsatz, offene Rechnungen und Zahlungen im Überblick.',
                },
            ].map(f => (
                <div class="relative bg-white/[0.03] border border-white/5 rounded-2xl p-6 opacity-70">
                    <div class="absolute top-4 right-4">
                        <span class="px-2 py-0.5 rounded-full bg-neutral-700/50 text-neutral-400 text-xs font-medium">Bald</span>
                    </div>
                    <div class="w-11 h-11 rounded-xl bg-white/5 flex items-center justify-center mb-4">
                        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#6B7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={f.icon}/>
                    </div>
                    <h3 class="text-base font-semibold text-neutral-300 mb-1.5">{f.title}</h3>
                    <p class="text-sm text-neutral-500 leading-relaxed">{f.desc}</p>
                </div>
            ))}

        </div>
    </section>

    <!-- How it works -->
    <section class="py-16 sm:py-20">
        <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-3">So einfach geht's</h2>
            <p class="text-neutral-400">In drei Schritten zur fertigen Rechnung.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 relative">
            <!-- Connector line (desktop) -->
            <div class="hidden sm:block absolute top-8 left-[calc(16.67%+1rem)] right-[calc(16.67%+1rem)] h-px bg-gradient-to-r from-brand-600/50 via-brand-500/50 to-brand-600/50"></div>

            {[
                { step: '01', title: 'Daten eingeben', desc: 'Trage deine Informationen und die des Kunden ein. Einmalig – du kannst sie beim nächsten Mal wiederverwenden.' },
                { step: '02', title: 'Positionen hinzufügen', desc: 'Füge deine Leistungen mit Menge und Preis hinzu. Die MwSt wird automatisch berechnet.' },
                { step: '03', title: 'PDF herunterladen', desc: 'Mit einem Klick erhältst du eine professionelle Rechnung als PDF – direkt zum Versenden.' },
            ].map(s => (
                <div class="flex flex-col items-center text-center">
                    <div class="w-16 h-16 rounded-2xl bg-brand-600/20 border border-brand-500/30 flex items-center justify-center mb-5 relative z-10">
                        <span class="text-brand-400 font-bold text-lg">{s.step}</span>
                    </div>
                    <h3 class="text-base font-semibold text-white mb-2">{s.title}</h3>
                    <p class="text-sm text-neutral-400 leading-relaxed">{s.desc}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- CTA -->
    <section class="py-16 sm:py-20">
        <div class="relative rounded-3xl overflow-hidden bg-gradient-to-br from-brand-900/60 to-brand-700/20 border border-brand-500/20 p-10 sm:p-14 text-center">
            <div class="absolute inset-0 pointer-events-none">
                <div class="absolute top-0 left-1/2 -translate-x-1/2 w-80 h-40 bg-brand-600/20 blur-[80px] rounded-full"></div>
            </div>
            <div class="relative">
                <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">Bereit loszulegen?</h2>
                <p class="text-neutral-300 text-lg mb-8 max-w-xl mx-auto">
                    Erstelle deine erste Rechnung in unter zwei Minuten – kostenlos und ohne Anmeldung.
                </p>
                <a href="/invoice" class="no-underline inline-flex items-center gap-2 px-8 py-4 bg-brand-600 hover:bg-brand-500 text-white font-bold rounded-xl transition shadow-xl shadow-brand-700/50 text-lg">
                    Jetzt Rechnung erstellen →
                </a>
            </div>
        </div>
    </section>

</Layout>
