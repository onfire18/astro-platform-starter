---
import Layout from '../layouts/Layout.astro';
import ContextAlert from '../components/ContextAlert.astro';

const softwareSkills = [
    {
        name: 'Adobe Premiere Pro',
        level: 95,
        description: 'Professioneller Videoschnitt, Multicam-Editing, Farbkorrektur'
    },
    {
        name: 'DaVinci Resolve',
        level: 90,
        description: 'Professionelles Color Grading, Fusion VFX, Fairlight Audio'
    },
    {
        name: 'Adobe After Effects',
        level: 85,
        description: 'Motion Graphics, Visual Effects, Compositing'
    },
    {
        name: 'Final Cut Pro',
        level: 80,
        description: 'Schneller Schnitt, Magnetic Timeline, Optimierte macOS-Performance'
    },
    {
        name: 'Adobe Audition',
        level: 75,
        description: 'Audio-Restaurierung, Mixing, Noise Reduction'
    },
    {
        name: 'CapCut / VN',
        level: 88,
        description: 'Social-Media-Content, Reels, TikTok-Videos'
    }
];

const techniques = [
    {
        icon: '🎨',
        title: 'Color Grading',
        description: 'Professionelle Farbkorrektur und kreatives Color Grading für cineastischen Look mit LUTs und manuellen Anpassungen.'
    },
    {
        icon: '✂️',
        title: 'Schnitt & Pacing',
        description: 'Rhythmischer Schnitt, J-Cuts, L-Cuts und dynamisches Pacing für maximale Zuschauerbindung.'
    },
    {
        icon: '🎵',
        title: 'Audio Design',
        description: 'Sound Design, Musik-Sync, Voice-Over-Integration und professionelle Audiomischung.'
    },
    {
        icon: '✨',
        title: 'Motion Graphics',
        description: 'Animierte Titel, Lower Thirds, Infografiken und Logo-Animationen mit After Effects.'
    },
    {
        icon: '🎬',
        title: 'Visual Effects',
        description: 'Green Screen, Compositing, Tracking und kreative VFX-Effekte.'
    },
    {
        icon: '📱',
        title: 'Social Media',
        description: 'Optimierte Formate für YouTube, Instagram Reels, TikTok und LinkedIn.'
    },
    {
        icon: '🏎️',
        title: 'Speed Ramping',
        description: 'Dynamische Geschwindigkeitsänderungen, Zeitlupe und Zeitraffer für dramatische Effekte.'
    },
    {
        icon: '🎭',
        title: 'Storytelling',
        description: 'Narrative Struktur, emotionaler Aufbau und wirkungsvolles Storytelling durch Schnitt.'
    }
];

const videoTypes = [
    { type: 'YouTube Videos', icon: '▶️' },
    { type: 'Werbefilme', icon: '📺' },
    { type: 'Musikvideos', icon: '🎶' },
    { type: 'Dokumentationen', icon: '🎥' },
    { type: 'Event-Videos', icon: '🎉' },
    { type: 'Reels & Shorts', icon: '📱' },
    { type: 'Corporate Videos', icon: '💼' },
    { type: 'Tutorial-Videos', icon: '📚' }
];
---

<Layout title="Video Editing Skills">
    <ContextAlert class="mb-4" />
    <h1 class="mb-4">Video Editing Skills</h1>
    <p class="text-lg text-white/80 mb-12 max-w-2xl">
        Professionelle Videobearbeitung von der Rohaufnahme zum fertigen Produkt –
        mit modernsten Tools und jahrelanger Erfahrung.
    </p>

    <!-- Software Skills -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8">Software & Tools</h2>
        <div class="grid gap-4 sm:grid-cols-2">
            {softwareSkills.map((skill) => (
                <div class="bg-white/10 rounded-xl p-5 backdrop-blur-sm border border-white/20">
                    <div class="flex justify-between items-center mb-2">
                        <span class="font-semibold text-white">{skill.name}</span>
                        <span class="text-white/70 text-sm font-mono">{skill.level}%</span>
                    </div>
                    <div class="w-full bg-white/20 rounded-full h-2 mb-3">
                        <div
                            class="bg-white rounded-full h-2 transition-all"
                            style={`width: ${skill.level}%`}
                        />
                    </div>
                    <p class="text-white/70 text-sm">{skill.description}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Techniques -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8">Techniken & Fähigkeiten</h2>
        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
            {techniques.map((tech) => (
                <div class="bg-white/10 rounded-xl p-5 backdrop-blur-sm border border-white/20 hover:bg-white/15 transition-colors">
                    <div class="text-3xl mb-3">{tech.icon}</div>
                    <h3 class="font-semibold text-white mb-2">{tech.title}</h3>
                    <p class="text-white/70 text-sm leading-relaxed">{tech.description}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Video Types -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8">Video-Formate</h2>
        <div class="flex flex-wrap gap-3">
            {videoTypes.map((v) => (
                <span class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-2 text-sm font-medium hover:bg-white/20 transition-colors">
                    <span>{v.icon}</span>
                    <span>{v.type}</span>
                </span>
            ))}
        </div>
    </section>

    <!-- Workflow -->
    <section class="mb-16">
        <h2 class="text-2xl font-bold mb-8">Workflow</h2>
        <div class="grid gap-0 sm:grid-cols-5">
            {[
                { step: '01', label: 'Material sichten', desc: 'Footage-Analyse & Auswahl' },
                { step: '02', label: 'Rough Cut', desc: 'Grobe Struktur & Timing' },
                { step: '03', label: 'Fine Cut', desc: 'Detailschnitt & Übergänge' },
                { step: '04', label: 'Post-Production', desc: 'Color, Audio & VFX' },
                { step: '05', label: 'Export', desc: 'Plattform-optimierter Output' }
            ].map((item, index) => (
                <div class="flex sm:flex-col items-center gap-4 sm:gap-2">
                    <div class="flex items-center sm:flex-col gap-2 sm:gap-0 flex-1">
                        <div class="bg-white text-[#355C7D] rounded-full w-10 h-10 flex items-center justify-center font-bold text-sm shrink-0 z-10">
                            {item.step}
                        </div>
                        {index < 4 && (
                            <div class="hidden sm:block h-0.5 w-full bg-white/30 -mt-5 mx-2" />
                        )}
                    </div>
                    <div class="sm:text-center min-w-0">
                        <p class="font-semibold text-white text-sm">{item.label}</p>
                        <p class="text-white/60 text-xs">{item.desc}</p>
                    </div>
                </div>
            ))}
        </div>
    </section>

    <!-- CTA -->
    <section class="mb-16">
        <div class="bg-white/10 rounded-2xl p-8 border border-white/20 text-center">
            <h2 class="text-2xl font-bold mb-3">Projekt anfragen</h2>
            <p class="text-white/70 mb-6 max-w-md mx-auto">
                Bereit für professionellen Videoschnitt? Lass uns gemeinsam deine Vision umsetzen.
            </p>
            <a href="mailto:media.drift.business@gmail.com" class="btn btn-lg btn-primary sm:btn-wide">
                Kontakt aufnehmen
            </a>
        </div>
    </section>
</Layout>
