---
import Layout from '../../layouts/Layout.astro';
import InvoiceGenerator from '../../components/InvoiceGenerator';
---

<Layout title="Rechnung erstellen" description="Erstelle professionelle Rechnungen als PDF – kostenlos, ohne Anmeldung, im deutschen Format.">
    <div class="py-8 sm:py-10 max-w-3xl mx-auto">
        <a href="/" class="inline-flex items-center gap-1.5 text-neutral-500 hover:text-brand-300 text-sm no-underline mb-8 transition">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6"/>
            </svg>
            Zurück zur Startseite
        </a>

        <div class="mb-8">
            <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-lg bg-brand-600/20 border border-brand-500/30 flex items-center justify-center">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#A78BFA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                    </svg>
                </div>
                <h1 class="text-2xl sm:text-3xl font-bold text-white" style="font-size: clamp(1.5rem, 4vw, 1.875rem);">Rechnung erstellen</h1>
            </div>
            <p class="text-neutral-400 text-sm sm:text-base">
                Fülle die Felder aus und lade deine fertige Rechnung als PDF herunter.
                Alle Daten bleiben in deinem Browser.
            </p>
        </div>

        <InvoiceGenerator client:load />
    </div>
</Layout>
