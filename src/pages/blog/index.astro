---
import MDLayout from '../../layouts/MDLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const featured = posts[0];
const rest = posts.slice(1);

const fmtDate = (d: Date) =>
  d.toLocaleDateString('de-DE', { day: 'numeric', month: 'long', year: 'numeric' });
---

<MDLayout
  title="Blog – Wissen rund um Website, Webdesign & Online-Marketing"
  description="Praktische Ratgeber zu Website-Kosten, Webdesign für KMU, DSGVO, Barrierefreiheit und mehr Kunden über die eigene Website. Klar, ehrlich und ohne Fachchinesisch."
>
  <!-- Hero -->
  <section class="blog-hero" aria-label="Blog">
    <div class="md-container">
      <span class="md-label">Blog</span>
      <h1 class="blog-hero-h1">Wissen rund um Ihre Website</h1>
      <p class="blog-hero-sub">
        Ehrliche Ratgeber zu Kosten, Technik und Strategie – damit Sie fundierte
        Entscheidungen für Ihren Online-Auftritt treffen. Ohne Fachchinesisch, ohne Verkaufsdruck.
      </p>
    </div>
  </section>

  <section class="md-section blog-list-section">
    <div class="md-container">

      {featured && (
        <a href={`/blog/${featured.slug}`} class="blog-featured">
          <div class="blog-featured-body">
            <span class="blog-cat">{featured.data.category}</span>
            <h2 class="blog-featured-title">{featured.data.title}</h2>
            <p class="blog-featured-desc">{featured.data.description}</p>
            <div class="blog-meta">
              <span>{fmtDate(featured.data.pubDate)}</span>
              {featured.data.readingTime && <span>· {featured.data.readingTime} Min. Lesezeit</span>}
            </div>
            <span class="blog-featured-link">Weiterlesen <span aria-hidden="true">→</span></span>
          </div>
        </a>
      )}

      <ul class="blog-grid" role="list">
        {rest.map((post) => (
          <li>
            <a href={`/blog/${post.slug}`} class="blog-card">
              <span class="blog-cat">{post.data.category}</span>
              <h3 class="blog-card-title">{post.data.title}</h3>
              <p class="blog-card-desc">{post.data.description}</p>
              <div class="blog-meta">
                <span>{fmtDate(post.data.pubDate)}</span>
                {post.data.readingTime && <span>· {post.data.readingTime} Min.</span>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="md-section blog-cta-section" aria-labelledby="blog-cta-h2">
    <div class="md-container">
      <div class="blog-cta-inner">
        <h2 id="blog-cta-h2">Lieber direkt über Ihr Projekt sprechen?</h2>
        <p>Wir entwickeln individuelle Websites für Unternehmen, die professioneller auftreten und online neue Kunden gewinnen möchten.</p>
        <a href="/#kontakt" class="md-btn md-btn-primary">Unverbindlichen Entwurf anfragen →</a>
      </div>
    </div>
  </section>
</MDLayout>

<style>
  .blog-hero {
    background:
      radial-gradient(ellipse 60% 70% at 85% 20%, rgba(20,85,168,0.16) 0%, transparent 60%),
      linear-gradient(160deg, #080C14 0%, #0C1828 60%, #0F172A 100%);
    padding-top: calc(var(--nav-h) + 4.5rem);
    padding-bottom: 4rem;
  }
  .blog-hero .md-label { color: #60A5FA; }
  .blog-hero-h1 {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    color: #F1F5F9;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    text-wrap: balance;
  }
  .blog-hero-sub {
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    color: #94A3B8;
    max-width: 60ch;
    line-height: 1.7;
    text-wrap: pretty;
  }

  .blog-list-section { background: var(--md-bg); }

  .blog-cat {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--md-cta);
    background: var(--md-accent);
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
    margin-bottom: 1rem;
  }
  .blog-meta { font-size: 0.82rem; color: var(--md-subtle); display: flex; gap: 0.35rem; }

  /* Featured */
  .blog-featured {
    display: block;
    background: var(--md-surface);
    border-radius: 16px;
    padding: clamp(1.75rem, 4vw, 3rem);
    margin-bottom: 2.5rem;
    border-left: 4px solid var(--md-cta);
    box-shadow: 0 1px 3px rgba(20, 85, 168, 0.06), 0 4px 20px rgba(20, 85, 168, 0.08);
    transition: box-shadow 280ms var(--ease-out), transform 280ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .blog-featured:hover {
      box-shadow: 0 4px 12px rgba(20, 85, 168, 0.1), 0 16px 48px rgba(20, 85, 168, 0.16);
      transform: translateY(-2px);
    }
  }
  .blog-featured-title {
    font-family: 'Outfit Variable', 'Outfit', system-ui, sans-serif;
    font-size: clamp(1.6rem, 3.2vw, 2.3rem);
    color: var(--md-primary);
    line-height: 1.15;
    margin-bottom: 0.85rem;
    text-wrap: balance;
  }
  .blog-featured-desc { color: var(--md-secondary); font-size: 1.05rem; line-height: 1.7; max-width: 65ch; margin-bottom: 1.1rem; }
  .blog-featured-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 1rem;
    color: var(--md-cta);
    font-weight: 600;
    font-size: 0.95rem;
    transition: gap 200ms var(--ease-out);
  }
  .blog-featured:hover .blog-featured-link { gap: 0.65rem; }

  /* Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--md-surface);
    border-radius: 12px;
    padding: 1.5rem;
    border-top: 3px solid transparent;
    box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
    transition:
      box-shadow 280ms var(--ease-out),
      border-color 280ms var(--ease-out),
      transform 280ms var(--ease-out);
  }
  @media (hover: hover) and (pointer: fine) {
    .blog-card:hover {
      box-shadow: 0 4px 12px rgba(20, 85, 168, 0.08), 0 12px 36px rgba(20, 85, 168, 0.12);
      border-top-color: var(--md-cta);
      transform: translateY(-3px);
    }
  }
  .blog-card-title {
    font-size: 1.1rem;
    line-height: 1.3;
    color: var(--md-primary);
    margin-bottom: 0.6rem;
    text-wrap: balance;
    font-weight: 600;
  }
  .blog-card-desc { color: var(--md-muted); font-size: 0.92rem; line-height: 1.6; flex: 1; margin-bottom: 1rem; }

  @media (max-width: 1100px) { .blog-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .blog-grid { grid-template-columns: 1fr; } }

  /* CTA */
  .blog-cta-section { background: var(--md-surface); border-top: 1px solid var(--md-border); }
  .blog-cta-inner { text-align: center; max-width: 600px; margin-inline: auto; }
  .blog-cta-inner p { color: var(--md-muted); margin: 1rem 0 2rem; font-size: 1.05rem; line-height: 1.7; }
</style>
